# ============================================
# POETIZE 博客系统配置文件
# ============================================
# 复制此文件为 .env 并根据需要修改配置
# cp .env.example .env

# ============================================
# Docker Compose Profiles 配置
# ============================================
# 启用的 profiles，逗号分隔 (https,mysql,redis)
# 此变量由脚本自动维护，无需手动修改
# 它确保 docker compose down 能正确停止所有相关容器
COMPOSE_PROFILES=https,mysql,redis

# ============================================
# 端口配置
# ============================================
# HTTP 端口 (默认 80)
HTTP_PORT=80
# HTTPS 端口 (默认 443)
HTTPS_PORT=443
# 是否启用 HTTPS (true/false)
ENABLE_HTTPS=true
# 是否启用内置 MySQL (true/false，使用外部数据库时设为false)
ENABLE_MYSQL=true
# 是否启用内置 Redis (true/false，使用外部Redis时设为false)
ENABLE_REDIS=true

# ============================================
# 域名配置
# ============================================
# 主域名
PRIMARY_DOMAIN=localhost
# 站点 URL (格式: protocol://domain)
SITE_URL=http://localhost

# ============================================
# 数据库配置
# ============================================
# 数据库类型 (mariadb/mysql)
DB_TYPE=mariadb
# 数据库主机
DB_HOST=mysql
# 数据库端口
DB_PORT=3306
# 数据库名称
DB_NAME=poetize
# 数据库用户名
DB_USER=poetize
# 数据库密码
DB_PASSWORD=poetize123
# 数据库 ROOT 密码 (仅内置数据库使用)
DB_ROOT_PASSWORD=root123

# ============================================
# Redis 配置
# ============================================
# Redis 主机
REDIS_HOST=redis
# Redis 端口
REDIS_PORT=6379
# Redis 密码
REDIS_PASSWORD=poetize_redis_2025
# Redis 数据库编号
REDIS_DB=0


# ============================================
# 版本信息 (部署时自动注入)
# ============================================
APP_VERSION=dev

# ============================================
# 安全配置
# ============================================
# AES 加密密钥 (前后端需一致，16字符)
POETIZE_AES_KEY=sarasarasarasara
# Token 密钥 (至少 32 字符)
TOKEN_SECRET_KEY=your_super_secure_random_key_here_at_least_32_chars

# ============================================
# Docker 网络配置
# ============================================
# Docker 子网
DOCKER_SUBNET=172.28.147.0/28
# Docker 网关
DOCKER_GATEWAY=172.28.147.1
# 各服务 IP 地址
IP_NGINX=172.28.147.2
IP_WEB=172.28.147.3
IP_CERTBOT=172.28.147.5
IP_PYTHON=172.28.147.6
IP_JAVA=172.28.147.7
IP_MYSQL=172.28.147.8
IP_PRERENDER=172.28.147.9
IP_REDIS=172.28.147.10
IP_MODEL=172.28.147.11
IP_ADMIN=172.28.147.12

# ============================================
# Java 服务配置
# ============================================
# JVM 参数
JAVA_OPTS=-Xmx768m -Xms512m -XX:MaxMetaspaceSize=192m -XX:CompressedClassSpaceSize=128m -Xss512k -XX:+UseZGC -XX:+UnlockExperimentalVMOptions -XX:+ExitOnOutOfMemoryError -XX:MaxRAMPercentage=75.0 -XX:+DisableExplicitGC

# ============================================
# 数据库驱动配置
# ============================================
# 数据库驱动类名 (mariadb: org.mariadb.jdbc.Driver, mysql: com.mysql.cj.jdbc.Driver)
DB_DRIVER_CLASS=org.mariadb.jdbc.Driver

# ============================================
# Druid 连接池配置
# ============================================
# 初始连接数
DRUID_INITIAL_SIZE=5
# 最小空闲连接数
DRUID_MIN_IDLE=5
# 最大活跃连接数
DRUID_MAX_ACTIVE=64

# ============================================
# OAuth 代理配置 (可选)
# ============================================
OAUTH_PROXY_DOMAIN=
