# 从离线包安装Docker
install_docker_offline() {
  info "使用离线安装包安装Docker..."
  
  if [ -f "./offline/docker.tar.gz" ]; then
    info "解压Docker离线安装包..."
    mkdir -p /tmp/docker_offline
    tar -xzf ./offline/docker.tar.gz -C /tmp/docker_offline
    
    if [ -f /tmp/docker_offline/install.sh ]; then
      info "执行离线安装脚本..."
      sudo chmod +x /tmp/docker_offline/install.sh
      /tmp/docker_offline/install.sh
      
      # 检查安装结果
      if command -v docker &>/dev/null; then
        success "从离线包安装Docker成功"
        return 0
      else
        warning "从离线包安装Docker失败，将尝试在线安装"
      fi
    elif [ -d /tmp/docker_offline/bin ]; then
      info "复制Docker二进制文件到系统路径..."
      # 复制二进制文件
      sudo cp -f /tmp/docker_offline/bin/* /usr/bin/ || cp -f /tmp/docker_offline/bin/* /usr/bin/
      
      # 设置执行权限
      sudo chmod +x /usr/bin/docker* || chmod +x /usr/bin/docker*
      
      # 如果有systemd服务文件，安装
      if [ -f /tmp/docker_offline/docker.service ]; then
        sudo cp -f /tmp/docker_offline/docker.service /etc/systemd/system/ || cp -f /tmp/docker_offline/docker.service /etc/systemd/system/
        sudo systemctl daemon-reload || true
        sudo systemctl enable docker || true
        sudo systemctl start docker || true
      fi
      
      # 检查安装结果
      if command -v docker &>/dev/null; then
        success "从离线二进制文件安装Docker成功"
        return 0
      else
        warning "从离线二进制文件安装Docker失败，将尝试在线安装"
      fi
    else
      warning "离线安装包格式不正确，将尝试在线安装"
    fi
  else
    warning "未找到离线Docker安装包"
  fi
  
  return 1
}

# 加载离线Docker镜像
load_offline_images() {
  if [ -d "./offline/images" ] && [ "$(ls -A ./offline/images/*.tar 2>/dev/null)" ]; then
    info "正在加载离线Docker镜像..."
    
    # 确保docker已安装
    if ! command -v docker &>/dev/null; then
      error "Docker未安装，无法加载镜像"
      return 1
    fi
    
    # 加载所有tar包中的镜像
    for image in ./offline/images/*.tar; do
      [ -f "$image" ] || continue
      
      image_name=$(basename "$image" .tar)
      info "加载镜像: $image_name"
      
      if docker load -i "$image"; then
        success "成功加载镜像: $image_name"
      else
        warning "加载镜像失败: $image_name"
      fi
    done
    
    # 显示已加载的镜像
    info "当前系统中的Docker镜像列表:"
    docker images
    
    return 0
  fi
  
  # warning "未找到离线Docker镜像文件"
  return 1
}

# 安全地运行Docker Compose命令，确保参数正确传递
run_docker_compose() {
    # 构建compose命令数组，自动探测版本，并根据需要加sudo
    local compose_cmd=()
    local capture_output=false
    local tmp_output=""

    # 探测compose版本
    if docker compose version &>/dev/null; then
      compose_cmd+=(docker compose)
    elif command -v docker-compose &>/dev/null; then
      compose_cmd+=(docker-compose)
    else
      error "未找到 docker compose / docker-compose，可执行文件！请提交issue"
      return 1
    fi

    # 如当前用户非 root 且 sudo 可用，追加 sudo
    if command -v sudo &>/dev/null && [[ $EUID -ne 0 ]]; then
      compose_cmd=(sudo "${compose_cmd[@]}")
    fi

    # 根据 ENABLE_HTTPS/MYSQL/REDIS 配置添加对应的 --profile
    local profile_args=()
    if [ -f "lib/config.sh" ]; then
      source "lib/config.sh"
      local enable_https=$(read_env_config "ENABLE_HTTPS" "true")
      local enable_mysql=$(read_env_config "ENABLE_MYSQL" "true")
      local enable_redis=$(read_env_config "ENABLE_REDIS" "true")
      
      [ "$enable_https" = "true" ] && profile_args+=(--profile https)
      [ "$enable_mysql" = "true" ] && profile_args+=(--profile mysql)
      [ "$enable_redis" = "true" ] && profile_args+=(--profile redis)
    else
      # 回退方案：使用全局变量
      [ "$ENABLE_HTTPS" = "true" ] || [ "$ENABLE_HTTPS" = true ] && profile_args+=(--profile https)
      [ "$ENABLE_MYSQL" = "true" ] || [ "$ENABLE_MYSQL" = true ] && profile_args+=(--profile mysql)
      [ "$ENABLE_REDIS" = "true" ] || [ "$ENABLE_REDIS" = true ] && profile_args+=(--profile redis)
    fi

    LAST_DOCKER_COMPOSE_CMD="${compose_cmd[*]} ${profile_args[*]} $*"
    LAST_DOCKER_COMPOSE_RC=0
    LAST_DOCKER_COMPOSE_ERROR_KIND=""
    LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=true

    if [ "$1" = "up" ]; then
      capture_output=true
      tmp_output=$(mktemp 2>/dev/null || printf "/tmp/poetize-compose-up-%s.log" "$$")
      LAST_DOCKER_COMPOSE_ERROR_FILE="$tmp_output"
    else
      LAST_DOCKER_COMPOSE_ERROR_FILE=""
    fi

    if [ "$capture_output" = true ]; then
      # 保留实时输出，同时保存原始错误供启动失败诊断使用
      "${compose_cmd[@]}" "${profile_args[@]}" "$@" > >(tee "$tmp_output") 2> >(tee -a "$tmp_output" >&2)
      LAST_DOCKER_COMPOSE_RC=$?
    else
      # shellcheck disable=SC2068
      "${compose_cmd[@]}" "${profile_args[@]}" "$@"
      LAST_DOCKER_COMPOSE_RC=$?
    fi

    return $LAST_DOCKER_COMPOSE_RC
}

get_last_compose_error_text() {
  if [ -n "$LAST_DOCKER_COMPOSE_ERROR_FILE" ] && [ -f "$LAST_DOCKER_COMPOSE_ERROR_FILE" ]; then
    cat "$LAST_DOCKER_COMPOSE_ERROR_FILE"
  fi
}

get_last_compose_error_summary() {
  local log_text=""
  log_text="$(get_last_compose_error_text)"
  if [ -z "$log_text" ]; then
    return 0
  fi

  echo "$log_text" | awk 'NF { lines[++count]=$0 } END { start=count-2; if (start < 1) start=1; for (i=start; i<=count; i++) print lines[i] }'
}

extract_port_from_compose_error() {
  local log_text="$1"
  local port=""

  port=$(echo "$log_text" | grep -oE '0\.0\.0\.0:[0-9]+' | head -1 | cut -d: -f2)
  if [ -z "$port" ]; then
    port=$(echo "$log_text" | grep -oE ':[0-9]+:[0-9]+(/tcp|/udp)?' | head -1 | cut -d: -f2)
  fi
  if [ -z "$port" ]; then
    port=$(echo "$log_text" | grep -oE 'port [0-9]+' | head -1 | grep -oE '[0-9]+')
  fi

  printf "%s" "$port"
}

classify_last_compose_failure() {
  local log_text=""
  log_text="$(get_last_compose_error_text)"
  LAST_DOCKER_COMPOSE_ERROR_KIND="unknown"
  LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=true

  if [ -z "$log_text" ]; then
    return 0
  fi

  if echo "$log_text" | grep -Eiq 'failed to bind host port|address already in use|port is already allocated'; then
    LAST_DOCKER_COMPOSE_ERROR_KIND="port_conflict"
    LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=false
  elif echo "$log_text" | grep -Eiq 'Cannot connect to the Docker daemon|Got permission denied while trying to connect to the Docker daemon socket'; then
    LAST_DOCKER_COMPOSE_ERROR_KIND="docker_daemon"
    LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=false
  elif echo "$log_text" | grep -Eiq 'permission denied'; then
    LAST_DOCKER_COMPOSE_ERROR_KIND="permission"
    LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=false
  elif echo "$log_text" | grep -Eiq 'no space left on device|ENOSPC'; then
    LAST_DOCKER_COMPOSE_ERROR_KIND="disk_full"
    LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=false
  elif echo "$log_text" | grep -Eiq 'pull access denied|TLS handshake timeout|i/o timeout|context deadline exceeded|connection reset by peer|temporary failure in name resolution'; then
    LAST_DOCKER_COMPOSE_ERROR_KIND="network"
    LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=true
  elif echo "$log_text" | grep -Eiq 'invalid compose project|has neither an image nor a build context specified|yaml|did not find expected|mapping values are not allowed|cannot unmarshal'; then
    LAST_DOCKER_COMPOSE_ERROR_KIND="compose_config"
    LAST_DOCKER_COMPOSE_ERROR_RECOVERABLE=false
  fi
}

print_compose_error_summary() {
  local summary=""
  summary="$(get_last_compose_error_summary)"
  if [ -n "$summary" ]; then
    info "最近一次原始错误摘要："
    while IFS= read -r line; do
      [ -n "$line" ] && info "  $line"
    done <<< "$summary"
  fi
}

print_compose_failure_guidance() {
  local kind="$1"
  local log_text=""
  local port=""

  log_text="$(get_last_compose_error_text)"

  case "$kind" in
    port_conflict)
      port="$(extract_port_from_compose_error "$log_text")"
      if [ -n "$port" ]; then
        error "检测到宿主机端口冲突：端口 $port 已被其他服务占用"
      else
        error "检测到宿主机端口冲突：80/443 等站点端口已被其他服务占用"
      fi
      info "处理建议："
      info "  1. 查看占用进程: ss -ltnp | grep ':80\\|:443'"
      info "  2. 如系统未安装 ss，可改用: lsof -i :80"
      info "  3. 如需保留现有面板/Nginx/CDN，请改用自定义端口部署: ./poetize install -d example.com:8080"
      info "  4. 也可显式指定: ./poetize install -d example.com --httpport 8080"
      info "  5. 使用自定义 HTTP 端口时，脚本会自动关闭项目内置 HTTPS，适合配合反向代理或 CDN"
      ;;
    docker_daemon)
      error "检测到 Docker 守护进程不可用或当前用户无权访问 Docker"
      info "处理建议："
      info "  1. 检查 Docker 状态: sudo docker info"
      info "  2. 如守护进程未启动，执行: sudo systemctl start docker"
      info "  3. 如为权限问题，请使用 root 或为当前用户配置 docker/sudo 权限后重试"
      ;;
    permission)
      error "检测到权限不足，当前环境无法完成 Docker 启动"
      info "处理建议："
      info "  1. 先验证权限: sudo docker info"
      info "  2. 使用 root 重新执行脚本，或为当前用户授予 sudo / docker 组权限"
      ;;
    disk_full)
      error "检测到与磁盘空间相关的 Docker 错误，当前启动无法继续"
      info "处理建议："
      info "  1. 先检查磁盘空间和 inode: df -h && df -i"
      info "  2. 如确认空间不足，再清理 Docker 资源: sudo docker system prune -af"
      info "  3. 如果磁盘空间比较小，建议扩容后重试"
      ;;
    network)
      error "检测到镜像拉取或网络连接异常，重试可能恢复"
      info "处理建议："
      info "  1. 检查服务器网络连通性和 DNS"
      info "  2. 若在国内环境，优先确认 Docker 镜像源是否可用"
      info "  3. 如问题持续，可执行: docker compose logs"
      ;;
    compose_config)
      error "检测到 Docker Compose 配置或参数错误，继续重试无法恢复"
      info "处理建议："
      info "  1. 检查 docker-compose.yml 和 .env 是否存在非法改动"
      info "  2. 执行配置校验: docker compose config"
      info "  3. 如是升级或自定义修改引入的问题，请回退到有效配置后重试"
      ;;
    *)
      error "服务启动失败，暂未识别到明确错误类型"
      info "处理建议："
      info "  1. 查看详细日志: docker compose logs"
      info "  2. 检查 Docker 守护进程、网络、自定义配置和最近一次原始错误摘要"
      info "  3. 如仍无法定位，请提交 Issue 并附上日志: $POETIZE_ISSUES_URL"
      ;;
  esac

  print_compose_error_summary
}


