        PULL_GHCR_MIRRORS="$reg"
        break
      fi
      echo "$reg 不可用，尝试下一个..."
    done

    sed_i "s|ghcr.io|$PULL_GHCR_MIRRORS|g" "docker/python/Dockerfile"
    success "已将 uv 镜像源替换国内镜像站"
    
