list_service_instances() {
    local base_service="$1"
    sudo docker ps -a --format "{{.Names}}" 2>/dev/null | grep -E "^${base_service}(-blog[0-9]+)?$" | sort || true
}

get_first_service_instance() {
    local base_service="$1"
    list_service_instances "$base_service" | head -n 1
}

read_env_file_value() {
    local key="$1"
    local env_file="${2:-.env}"
    [ -f "$env_file" ] || return 1

    grep -E "^${key}=" "$env_file" 2>/dev/null | tail -n 1 | cut -d'=' -f2- | tr -d '"' | tr -d "'" | tr -d '[:space:]'
}

resolve_compose_port_expr() {
    local expr="$1"
    local env_file="${ENV_FILE_OVERRIDE:-.env}"
    local env_key=""
    local default_value=""
    local env_value=""

    if [[ "$expr" =~ ^\$\{([A-Za-z_][A-Za-z0-9_]*)[:-]-(.+)\}$ ]]; then
        env_key="${BASH_REMATCH[1]}"
        default_value="${BASH_REMATCH[2]}"
        env_value="$(read_env_file_value "$env_key" "$env_file")"
        if [ -n "$env_value" ]; then
            printf "%s\n" "$env_value"
        else
            printf "%s\n" "$default_value"
        fi
        return 0
    fi

    printf "%s\n" "$expr"
}

list_container_port_bindings() {
    local container_name="$1"
    local compose_file="${2:-docker-compose.yml}"
    local env_file="${3:-.env}"
    local line=""
    local seen=""
    local raw_ports=""
    local mapping=""
    local host_part=""
    local container_part=""
    local host_port=""

    if [ -n "$container_name" ]; then
        raw_ports="$(sudo docker port "$container_name" 2>/dev/null || true)"
        if [ -n "$raw_ports" ]; then
            while IFS= read -r line; do
                [ -z "$line" ] && continue
                container_part="$(printf "%s" "$line" | awk '{print $1}')"
                host_part="$(printf "%s" "$line" | awk -F'-> ' '{print $2}' | sed 's/^[[:space:]]*//')"
                host_port="$(printf "%s" "$host_part" | sed 's/.*://')"
                mapping="${host_port}|${container_part}"
                case "|$seen|" in
                    *"|$mapping|"*) ;;
                    *)
                        printf "%s\n" "$mapping"
                        seen="${seen}|${mapping}"
                        ;;
                esac
            done <<< "$raw_ports"
            return 0
        fi
    fi

    while IFS= read -r line; do
        [ -z "$line" ] && continue
        line="$(printf "%s" "$line" | sed 's/^[[:space:]]*-[[:space:]]*//' | tr -d '"')"
        host_part="$(printf "%s" "$line" | cut -d: -f1)"
        container_part="$(printf "%s" "$line" | cut -d: -f2-)"
        host_port="$(ENV_FILE_OVERRIDE="$env_file" resolve_compose_port_expr "$host_part")"
        mapping="${host_port}|${container_part}"
        case "|$seen|" in
            *"|$mapping|"*) ;;
            *)
                printf "%s\n" "$mapping"
                seen="${seen}|${mapping}"
                ;;
        esac
    done < <(
        awk '
            /^[[:space:]]*nginx:[[:space:]]*$/ { in_nginx=1; next }
            in_nginx && /^[^[:space:]]/ { in_nginx=0; in_ports=0 }
            in_nginx && /^[[:space:]]*ports:[[:space:]]*$/ { in_ports=1; next }
            in_ports && /^[[:space:]]*[A-Za-z0-9_-]+:[[:space:]]*$/ { in_ports=0 }
            in_ports && /^[[:space:]]*-[[:space:]]*"/ { print }
        ' "$compose_file" 2>/dev/null
    )
}

list_nginx_port_bindings() {
    local nginx_container=""
    nginx_container="$(get_first_service_instance "poetize-nginx")"
    list_container_port_bindings "$nginx_container" "docker-compose.yml" ".env"
}

print_section_header() {
    local title="$1"
    local line="=========================================================================="
    printf "${CYAN}%s${NC}\n" "$line"
    printf "${CYAN}=== %s ===${NC}\n" "$title"
    printf "${CYAN}%s${NC}\n" "$line"
}

print_table_separator() {
    printf "  %-12s %-25s %-18s %s\n" "------------" "-------------------------" "------------------" "------------------------------"
}

print_table_header() {
    printf "  %-12s %-25s %-18s %s\n" "状态" "容器" "类型" "说明"
    print_table_separator
}

format_status_cell() {
    local status="$1"
    local padded
    padded=$(printf "%-12s" "$status")
    case "$status" in
        "OK")
            printf "%b%s%b" "$GREEN" "$padded" "$NC"
            ;;
        "WARN")
            printf "%b%s%b" "$YELLOW" "$padded" "$NC"
            ;;
        "FAIL")
            printf "%b%s%b" "$RED" "$padded" "$NC"
            ;;
        *)
            printf "%b%s%b" "$BLUE" "$padded" "$NC"
            ;;
    esac
}

print_table_row() {
    local status="$1"
    local container_name="$2"
    local service_type="$3"
    local message="$4"
    printf "  %s %-25s %-18s %s\n" "$(format_status_cell "$status")" "$container_name" "$service_type" "$message"
}

resolve_project_version() {
    local project_dir="$1"
    local deployed_version=""
    local app_version=""
    local git_version=""

    if [ -n "$project_dir" ] && [ -f "$project_dir/.config/version.txt" ]; then
        deployed_version=$(grep "^VERSION=" "$project_dir/.config/version.txt" 2>/dev/null | cut -d'=' -f2)
        if [ -n "$deployed_version" ]; then
            printf "%s\n" "$deployed_version"
            return 0
        fi
    fi

    if [ -n "$project_dir" ] && [ -f "$project_dir/.env" ]; then
        app_version=$(grep "^APP_VERSION=" "$project_dir/.env" 2>/dev/null | tail -n 1 | cut -d'=' -f2- | tr -d '"' | tr -d "'" | tr -d '[:space:]')
        if [ -n "$app_version" ] && [ "$app_version" != "dev" ]; then
            printf "%s\n" "$app_version"
            return 0
        fi
    fi

    if [ -n "$project_dir" ] && [ -d "$project_dir/.git" ]; then
        git_version=$(git -C "$project_dir" describe --tags --abbrev=0 2>/dev/null || true)
        if [ -n "$git_version" ]; then
            printf "%s\n" "$git_version"
            return 0
        fi
    fi

    return 1
}

normalize_version_string() {
    local version="$1"
    version="${version#v}"
    printf "%s\n" "$version"
}

version_gte() {
    local current
    local target
    current=$(normalize_version_string "$1")
    target=$(normalize_version_string "$2")

    if [ -z "$current" ] || [ -z "$target" ]; then
        return 1
    fi

    local lower_version
    lower_version=$(printf "%s\n%s" "$target" "$current" | sort -V | head -1)
    [ "$lower_version" = "$target" ]
}

project_requires_python_backend() {
