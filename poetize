          info "已设置 CN_FONT_SPLIT_GH_HOST=$CN_FONT_SPLIT_GH_HOST"
        else
          warning "未探测到可用的 cn-font-split GitHub 代理，将使用 Dockerfile 默认地址"
        fi
      fi
    else
      info "已跳过 Dockerfile 加速处理"
    fi
  fi

  # 初始化SKIP_BUILD变量，默认为空
