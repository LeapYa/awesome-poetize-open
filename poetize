# 初始化部署
init_deploy() {
  info "正在初始化部署环境..."
  
  # 配置系统时区
  setup_timezone
  
  # 配置swap空间
  setup_swap

  # 检查是否使用外部数据库或Redis
  if [ -n "$DB_HOST" ] || [ -n "$REDIS_HOST" ]; then
    # 使用外部数据库或Redis
    info "检测到外部数据库/Redis配置..."

    # 恢复可能被注释的mysql和redis服务（为重新配置做准备）
    restore_mysql_service
    restore_redis_service

    # 更新数据库和Redis连接配置
    update_db_connection_config
    update_redis_connection_config

    # 如果使用MySQL，替换poetry.sql为poetry_old.sql（兼容MySQL语法）
    if [ "$DB_TYPE" = "mysql" ]; then
      info "检测到MySQL数据库，替换poetry.sql为兼容版本..."
      if [ -f "poetize-server/sql/poetry_old.sql" ]; then
        cp "poetize-server/sql/poetry_old.sql" "poetize-server/sql/poetry.sql"
        success "已替换为MySQL兼容版本"
      else
        warning "未找到poetry_old.sql文件，将使用原始poetry.sql"
      fi
    fi

    # 保存配置到文件
    save_redis_config
    save_db_credentials_extended

    # 根据配置禁用不需要的容器
    if [ -n "$DB_HOST" ]; then
      disable_mysql_service
    fi

    if [ -n "$REDIS_HOST" ]; then
      disable_redis_service
    fi

    success "外部数据库/Redis配置完成"
  else
    # 使用本地数据库和Redis
    # 替换默认数据库密码为随机强密码
    replace_db_passwords

    # 替换默认Redis密码为随机强密码
    replace_redis_password
  fi

  if [ "${POETIZE_UPDATE_MODE:-false}" != "true" ] && [ -f ".env" ]; then
    # 配置Docker Compose AES密钥
    replace_docker_compose_aes_key

    # 配置Docker Compose Token密钥
    generate_token_secret_key
  else
    info "【更新模式】保留现有 AES 及 Token 密钥"
  fi

  # 设置域名
  info "更新Nginx配置中的域名..."
  if [ -n "$PRIMARY_DOMAIN" ]; then
    render_nginx_configs

    # 使用 .env 文件配置域名相关变量
    if [ -f "lib/config.sh" ]; then
      source "lib/config.sh"
      update_env_var "PRIMARY_DOMAIN" "$PRIMARY_DOMAIN"
      # 根据 HTTPS 状态设置协议和 SITE_URL
      local protocol="http"
      if [ "$ENABLE_HTTPS" = "true" ]; then
        protocol="https"
      fi
      update_env_var "SITE_URL" "${protocol}://${PRIMARY_DOMAIN}"
      success "已更新域名配置 (通过 .env)"
    else
      # 回退方案：直接修改 docker-compose.yml
      sed_i "s/SITE_URL=http:\/\/example.com/SITE_URL=http:\/\/$PRIMARY_DOMAIN/g" docker-compose.yml
      
      if project_requires_python_backend; then
        info "更新旧版 Python 后端 FRONTEND_HOST 环境变量为: $PRIMARY_DOMAIN"
        if grep -q "FRONTEND_HOST=" docker-compose.yml; then
          sed_i "s/- FRONTEND_HOST=example.com/- FRONTEND_HOST=$PRIMARY_DOMAIN/g" docker-compose.yml
          success "已更新FRONTEND_HOST环境变量"
        else
          info "未在docker-compose.yml中找到FRONTEND_HOST环境变量配置，将添加此配置"
          # 查找python-backend服务的environment部分
          if grep -q "python-backend:" docker-compose.yml; then
            # 最后一个python环境变量是JAVA_BACKEND_PORT=8081
            JAVA_BACKEND_PORT_LINE=$(grep -n "JAVA_BACKEND_PORT=8081" docker-compose.yml | cut -d: -f1)
            if [ -n "$JAVA_BACKEND_PORT_LINE" ]; then
              # 在JAVA_BACKEND_PORT行后添加FRONTEND_HOST
              sed_i "${JAVA_BACKEND_PORT_LINE}a\\      - FRONTEND_HOST=$PRIMARY_DOMAIN" docker-compose.yml
              success "已添加FRONTEND_HOST环境变量"
            fi
          fi
        fi
      else
        info "当前版本无需修改独立 Python 后端 FRONTEND_HOST 配置"
      fi
    fi
    
    # 根据域名类型决定是否启用"禁止IP直接访问"功能
    # 如果用户输入的是IP地址，则删除IP拦截配置；如果是域名，则保留
    configure_ip_access_block
  else
    error "主域名为空，无法更新Nginx配置"
    exit 1
  fi
  
  # 确保初始时使用HTTP配置
  info "设置初始Nginx配置为HTTP模式..."
  cp docker/nginx/default.http.conf docker/nginx/default.conf
  
  # 配置自定义HTTP端口（如果指定了--httpport参数或域名:端口格式）
  configure_http_port
  
  # 根据ENABLE_HTTPS配置certbot（ENABLE_HTTPS已在check_and_configure_https_mode中统一设置）
  # 注意：如果有自定义端口，certbot已在configure_http_port中禁用，这里跳过
  if [ "$ENABLE_HTTPS" = false ] && [ -z "$HTTP_PORT" ]; then
    info "HTTPS已禁用，禁用certbot容器"
    disable_certbot_service
  elif [ "$ENABLE_HTTPS" = true ]; then
    # HTTPS已启用，配置certbot参数
    info "HTTPS已启用，配置certbot参数"
    DOMAINS_PARAM=" -d $PRIMARY_DOMAIN"
    for domain in "${DOMAINS[@]}"; do
      [ "$domain" = "$PRIMARY_DOMAIN" ] && continue
      DOMAINS_PARAM="$DOMAINS_PARAM -d $domain"
    done
    
    # 从模板恢复 certbot-entrypoint.sh（确保可重复修改）
    if [ -f "docker/nginx/certbot-entrypoint.sh.template" ]; then
      cp "docker/nginx/certbot-entrypoint.sh.template" "docker/nginx/certbot-entrypoint.sh"
      info "已从模板恢复 certbot-entrypoint.sh"
    fi
    
    # 使用sed替换certbot命令行certbot-entrypoint.sh
    sed_i "s|--email your-email@example.com|--email $EMAIL|g" docker/nginx/certbot-entrypoint.sh
    sed_i "s|--cert-name example.com|--cert-name $PRIMARY_DOMAIN|g" docker/nginx/certbot-entrypoint.sh
    sed_i "s|-d example.com -d www.example.com|$DOMAINS_PARAM|g" docker/nginx/certbot-entrypoint.sh
    # 替换DNS检查中的遗留占位域名
    sed_i "s|check_dns \"example.com\"|check_dns \"$PRIMARY_DOMAIN\"|g" docker/nginx/certbot-entrypoint.sh
    
    success "成功更新certbot-entrypoint.sh中的邮箱和域名参数"
  fi
  
  success "部署环境初始化完成"
}

get_secondary_domains() {
  local secondary_domains=""
  local d
  for d in "${DOMAINS[@]}"; do
    if [ "$d" != "$PRIMARY_DOMAIN" ]; then
      secondary_domains="$secondary_domains $d"
    fi
  done

  if [ -n "$secondary_domains" ]; then
    secondary_domains=$(echo "$secondary_domains" | awk '{$1=$1;print}')
  fi

  printf "%s\n" "$secondary_domains"
}

extract_server_names_from_nginx_file() {
  local nginx_config_file="$1"

  [ -f "$nginx_config_file" ] || return 1

  awk '
    /# AUTO_REDIRECT_SECONDARY_DOMAINS_START/ { in_auto_redirect = 1; next }
    /# AUTO_REDIRECT_SECONDARY_DOMAINS_END/ { in_auto_redirect = 0; next }
    in_auto_redirect { next }
    /^[[:space:]]*server_name[[:space:]]+/ {
      line = $0
      sub(/^[[:space:]]*server_name[[:space:]]+/, "", line)
      sub(/;.*/, "", line)
      count = split(line, names, /[[:space:]]+/)
      for (i = 1; i <= count; i++) {
        if (names[i] != "" && names[i] != "_" && names[i] != "example.com" && names[i] != "www.example.com") {
          print names[i]
        }
      }
    }
  ' "$nginx_config_file" | sort -u
}

render_nginx_config_file() {
  local conf_file="$1"
  local primary_domain="$2"
  local secondary_domains="$3"

  [ -f "$conf_file" ] || return 0

  sed '/# AUTO_REDIRECT_SECONDARY_DOMAINS_START/,$d; /# 自动追加的副域名 301 重定向模块/,$d' "$conf_file" | \
  awk -v primary="$primary_domain" -v secondary="$secondary_domains" -v conf_file="$conf_file" '
  {
    if ($0 ~ /valid_referers/) {
      # server_names 关键字已自动包含当前 server_name 的值，
      # 只需移除旧的域名占位符，不再追加域名，避免与 server_names 重复导致
      # nginx 报 "conflicting parameter" 错误（尤其 localhost/IP 部署场景）
      old_ref = "~\\.example\\.com$ example.com"
      if ((pos = index($0, old_ref)) > 0) {
        $0 = substr($0, 1, pos - 1) substr($0, pos + length(old_ref))
      }
      print $0
    } else {
      # 主站 server_name 仅绑定主域名，副域名通过单独 server 块做 301 跳转
      gsub(/server_name[[:space:]]+example\.com[[:space:]]+www\.example\.com;/, "server_name " primary ";")
      # 替换证书路径等单域名占位符
      gsub(/example\.com\//, primary "/")
      print $0
    }
  }
  END {
    if (secondary != "") {
      print ""
      print "# AUTO_REDIRECT_SECONDARY_DOMAINS_START"
      print "# 自动追加的副域名 301 重定向模块"
      if (conf_file ~ /https/) {
        print "server {"
        print "    listen 80;"
        print "    server_name " secondary ";"
        print ""
        print "    location ^~ /.well-known/acme-challenge/ {"
        print "        root /usr/share/nginx/html;"
        print "        allow all;"
        print "        try_files $uri =404;"
        print "    }"
        print ""
        print "    return 301 https://" primary "$request_uri;"
        print "}"
        print "server {"
        print "    listen 443 ssl;"
        print "    listen 443 quic;"
        print "    http2 on;"
        print "    http3 on;"
        print "    server_name " secondary ";"
        print "    ssl_certificate /etc/letsencrypt/live/" primary "/fullchain.pem;"
        print "    ssl_certificate_key /etc/letsencrypt/live/" primary "/privkey.pem;"
        print "    return 301 https://" primary "$request_uri;"
        print "}"
      } else {
        print "server {"
        print "    listen 80;"
        print "    server_name " secondary ";"
        print ""
        print "    location ^~ /.well-known/acme-challenge/ {"
        print "        root /usr/share/nginx/html;"
        print "        allow all;"
        print "        try_files $uri =404;"
        print "    }"
        print ""
        print "    return 301 http://" primary "$request_uri;"
        print "}"
      }
      print "# AUTO_REDIRECT_SECONDARY_DOMAINS_END"
    }
  }' > "${conf_file}.tmp" && chmod 644 "${conf_file}.tmp" && mv "${conf_file}.tmp" "$conf_file"
}

render_nginx_configs() {
  local secondary_domains
  local conf_file

  secondary_domains=$(get_secondary_domains)

