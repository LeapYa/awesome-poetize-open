#!/bin/bash
## 作者: LeapYa
## 修改时间: 2026-03-10
## 描述: POETIZE 博客系统全局管理命令
## 版本: 1.10.0

# 定义颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 全局变量
UPDATE_VERSION=""  # 升级到指定版本（空则使用最新稳定版本）
USE_LATEST_TAG=true  # 是否使用最新稳定标签（false则使用main分支）
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"
LOCAL_CORE_DIR="$PROJECT_ROOT/lib/core"
GLOBAL_CORE_DIR="/usr/local/lib/poetize/core"
BOOTSTRAP_CORE_DIR=""
DEPLOY_CORE_SCRIPT="$LOCAL_CORE_DIR/deploy-core.sh"
MIGRATE_CORE_SCRIPT="$LOCAL_CORE_DIR/migrate-core.sh"

# 函数
info() { echo -e "${BLUE}[信息]${NC} $1"; }
success() { echo -e "${GREEN}[成功]${NC} $1"; }
error() { echo -e "${RED}[失败]${NC} $1"; }
warning() { echo -e "${YELLOW}[警告]${NC} $1"; }

bootstrap_is_china_environment() {
    if command -v curl >/dev/null 2>&1; then
        if ! curl -s --connect-timeout 3 --max-time 5 "https://www.google.com" >/dev/null 2>&1; then
            if curl -s --connect-timeout 3 --max-time 5 "http://mirrors.aliyun.com" >/dev/null 2>&1; then
                return 0
            fi
        fi
    fi
    return 1
}

resolve_bootstrap_ref() {
    if [ -n "$UPDATE_VERSION" ]; then
        printf "%s\n" "$UPDATE_VERSION"
        return 0
    fi

    if [ "$USE_LATEST_TAG" = "false" ]; then
        printf "main\n"
        return 0
    fi

    local release_tag=""
    if bootstrap_is_china_environment; then
        release_tag=$(curl -fsSL "https://gitee.com/api/v5/repos/leapya/poetize/releases/latest" 2>/dev/null | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    else
        release_tag=$(curl -fsSL "https://api.github.com/repos/LeapYa/Awesome-poetize-open/releases/latest" 2>/dev/null | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)
    fi

    if [ -n "$release_tag" ]; then
        printf "%s\n" "$release_tag"
    else
        printf "main\n"
    fi
}

ensure_bootstrap_core_dir() {
    if [ -n "$BOOTSTRAP_CORE_DIR" ] && [ -d "$BOOTSTRAP_CORE_DIR" ]; then
        return 0
    fi

    if command -v mktemp >/dev/null 2>&1; then
        BOOTSTRAP_CORE_DIR=$(mktemp -d /tmp/poetize-core.XXXXXX 2>/dev/null || true)
    fi

    if [ -z "$BOOTSTRAP_CORE_DIR" ]; then
        BOOTSTRAP_CORE_DIR="/tmp/poetize-core-bootstrap"
        mkdir -p "$BOOTSTRAP_CORE_DIR"
    fi

    [ -d "$BOOTSTRAP_CORE_DIR" ]
}

list_bootstrap_base_urls() {
    local ref="$1"
    local github_base="https://raw.githubusercontent.com/LeapYa/Awesome-poetize-open/${ref}"
    local gitee_base="https://gitee.com/leapya/poetize/raw/${ref}"

    if [ -n "${POETIZE_BOOTSTRAP_BASE_URL:-}" ]; then
        printf "%s\n" "${POETIZE_BOOTSTRAP_BASE_URL%/}/${ref}"
    fi

    if bootstrap_is_china_environment; then
        printf "%s\n%s\n" "$gitee_base" "$github_base"
    else
        printf "%s\n%s\n" "$github_base" "$gitee_base"
    fi
}

download_file_to_path() {
    local url="$1"
    local target_path="$2"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL --connect-timeout 8 --retry 2 --retry-delay 1 "$url" -o "$target_path" >/dev/null 2>&1
        return $?
    fi

    if command -v wget >/dev/null 2>&1; then
        wget -q -O "$target_path" "$url" >/dev/null 2>&1
        return $?
    fi

    warning "当前环境缺少 curl/wget，无法下载核心脚本" >&2
    return 1
}

download_bootstrap_core_script() {
    local script_name="$1"
    local target_path="$2"
    local ref=""
    local download_url=""
    local attempted_urls=()

    ensure_bootstrap_core_dir || return 1
    ref=$(resolve_bootstrap_ref)

    while IFS= read -r raw_base; do
        [ -n "$raw_base" ] || continue
        download_url="${raw_base}/lib/core/${script_name}"
        attempted_urls+=("$download_url")
        if download_file_to_path "$download_url" "$target_path"; then
            chmod +x "$target_path" 2>/dev/null || true
            return 0
        fi
    done < <(list_bootstrap_base_urls "$ref")

    warning "核心脚本下载失败，已尝试以下地址：" >&2
    local attempted_url=""
    for attempted_url in "${attempted_urls[@]}"; do
        warning "  - $attempted_url" >&2
    done
    rm -f "$target_path" 2>/dev/null || true
    return 1
}

resolve_core_script() {
    local script_name="$1"
    if [ -f "$LOCAL_CORE_DIR/$script_name" ]; then
        printf "%s\n" "$LOCAL_CORE_DIR/$script_name"
        return 0
    fi
    if [ -f "$GLOBAL_CORE_DIR/$script_name" ]; then
        printf "%s\n" "$GLOBAL_CORE_DIR/$script_name"
        return 0
    fi
    if ensure_bootstrap_core_dir; then
        local bootstrap_script="$BOOTSTRAP_CORE_DIR/$script_name"
        if [ ! -f "$bootstrap_script" ]; then
            info "正在下载核心脚本: $script_name" >&2
            download_bootstrap_core_script "$script_name" "$bootstrap_script" || return 1
        fi
        if [ -f "$bootstrap_script" ]; then
            printf "%s\n" "$bootstrap_script"
            return 0
        fi
    fi
    return 1
}

run_core_script() {
    local script_name="$1"
    shift

    local core_script=""
    core_script=$(resolve_core_script "$script_name") || {
        error "未找到核心脚本: $script_name"
        error "请确保项目目录中的 lib/core 已完整存在，或检查 install.leapya.com / GitHub / Gitee 是否可访问"
        exit 1
    }

    chmod +x "$core_script" 2>/dev/null || true
    bash "$core_script" "$@"
}

# 引入配置管理库
load_config_lib() {
    if [ -f "lib/config.sh" ]; then
        source "lib/config.sh"
        return 0
    fi
    return 1
}

# 检查用户权限
check_user_permissions() {
    # 检查是否为root用户
    if [ "$EUID" -eq 0 ]; then
        return 0  # root用户，权限充足
    fi
    
    # 检查是否在docker组中
    if groups "$USER" 2>/dev/null | grep -q "\bdocker\b"; then
        return 0  # 在docker组中，权限充足
    fi
    
    # 检查是否有sudo权限
    if sudo -n true 2>/dev/null; then
        # 检查当前是否以sudo方式运行
        if [ -z "$SUDO_USER" ]; then
            warning "当前用户不在docker组中，但具有sudo权限"
            warning "建议使用sudo运行以确保Docker访问权限："
            printf "  ${YELLOW}推荐方式：${NC} sudo poetize [选项]\n"
            printf "  ${YELLOW}或添加到docker组：${NC} sudo usermod -aG docker $USER && newgrp docker\n"
        else
            info "以sudo权限运行，权限充足"
        fi
        return 0  # 有sudo权限，可以继续
    fi
    
    # 权限不足
    error "权限不足！当前用户既不是root用户，也不在docker组中，且无sudo权限"
    error "请执行以下操作之一："
    printf "  ${YELLOW}1. 切换到root用户：${NC} su -\n"
    printf "  ${YELLOW}2. 切换到有sudo权限的用户${NC}\n"
    printf "  ${YELLOW}3. 将当前用户添加到docker组：${NC} sudo usermod -aG docker $USER\n"
    printf "  ${YELLOW}4. 使用sudo运行：${NC} sudo poetize [选项]\n"
    exit 1
}

# 检查Docker和Docker Compose
check_docker() {
    if ! command -v docker &> /dev/null; then
        error "Docker未安装或未在PATH中"
        exit 1
    fi
    
    # 检查用户权限
    check_user_permissions
    
    # 尝试访问Docker
    if ! docker info &> /dev/null; then
        # 如果直接访问失败，尝试使用sudo
        if [ "$EUID" -ne 0 ] && ! groups "$USER" 2>/dev/null | grep -q "\bdocker\b"; then
            if sudo docker info &> /dev/null 2>&1; then
                warning "使用sudo权限访问Docker"
                DOCKER_COMPOSE_CMD="sudo docker-compose"
                # 重新定义docker命令为sudo版本
                alias docker='sudo docker' 2>/dev/null || true
            else
                error "Docker服务未运行或权限不足"
                exit 1
            fi
        else
            error "Docker服务未运行"
            exit 1
        fi
    fi
    
    # 检查docker-compose或docker compose
    if command -v docker-compose &> /dev/null; then
        DOCKER_COMPOSE_CMD="${DOCKER_COMPOSE_CMD:-docker-compose}"
    elif docker compose version &> /dev/null 2>&1 || sudo docker compose version &> /dev/null 2>&1; then
        DOCKER_COMPOSE_CMD="${DOCKER_COMPOSE_CMD:-docker} compose"
    else
        error "Docker Compose未安装"
        exit 1
    fi
}

