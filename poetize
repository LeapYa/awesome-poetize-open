# ================================ UPDATE 命令相关函数 ================================

escape_regex() {
    printf "%s" "$1" | sed 's/[][(){}.^$*+?|\\/]/\\&/g'
}

get_compose_project_name() {
    if [ -n "$COMPOSE_PROJECT_NAME" ]; then
        printf "%s\n" "$COMPOSE_PROJECT_NAME"
    elif [ -n "$POETIZE_PROJECT_NAME" ]; then
        printf "%s\n" "$(printf "%s" "$POETIZE_PROJECT_NAME" | tr '[:upper:]' '[:lower:]')"
    else
        basename "$(pwd)" | tr '[:upper:]' '[:lower:]'
    fi
}

resolve_compose_container_name() {
    local service_name="$1"
    local container_id=""
    local container_name=""

    container_id=$($DOCKER_COMPOSE_CMD ps -a -q "$service_name" 2>/dev/null | head -n 1)
    if [ -n "$container_id" ]; then
        container_name=$(sudo docker inspect --format '{{.Name}}' "$container_id" 2>/dev/null | sed 's#^/##')
        if [ -n "$container_name" ]; then
            printf "%s\n" "$container_name"
            return 0
        fi
    fi

    return 1
}

resolve_project_volume_name() {
    local logical_volume="$1"
    local compose_project_name=""
    local escaped_project_name=""
    local escaped_logical_volume=""
    local volume_name=""

    compose_project_name=$(get_compose_project_name)

    if [ -n "$compose_project_name" ]; then
        volume_name="${compose_project_name}_${logical_volume}"
        if sudo docker volume inspect "$volume_name" >/dev/null 2>&1; then
            printf "%s\n" "$volume_name"
            return 0
        fi
    fi

    if sudo docker volume inspect "$logical_volume" >/dev/null 2>&1; then
        printf "%s\n" "$logical_volume"
        return 0
    fi

    escaped_project_name=$(escape_regex "$compose_project_name")
    escaped_logical_volume=$(escape_regex "$logical_volume")
    sudo docker volume ls --format "{{.Name}}" | \
        grep -E "^${escaped_project_name}_${escaped_logical_volume}([_-].*)?$|^${escaped_logical_volume}([_-].*)?$" | \
        head -n 1
}

resolve_service_volume_name() {
    local service_name="$1"
    local mount_destination="$2"
    local logical_volume="$3"
    local container_name=""
    local volume_name=""

    container_name=$(resolve_compose_container_name "$service_name" 2>/dev/null || true)
    if [ -n "$container_name" ]; then
        volume_name=$(sudo docker inspect --format "{{range .Mounts}}{{if eq .Destination \"$mount_destination\"}}{{.Name}}{{end}}{{end}}" "$container_name" 2>/dev/null)
        if [ -n "$volume_name" ]; then
            printf "%s\n" "$volume_name"
            return 0
        fi
    fi

    resolve_project_volume_name "$logical_volume"
}

resolve_db_root_password() {
    local mariadb_container="${1:-}"
    local env_password=""
    local config_password=""
    local container_password=""
    local candidates=()
    local candidate=""

    add_db_password_candidate() {
        local new_candidate="$1"
        local existing=""

        [ -n "$new_candidate" ] || return 0
        for existing in "${candidates[@]}"; do
            if [ "$existing" = "$new_candidate" ]; then
                return 0
            fi
        done
        candidates+=("$new_candidate")
    }

    if [ -f ".env" ] && type read_env_config &>/dev/null; then
        env_password=$(read_env_config "DB_ROOT_PASSWORD" "")
        add_db_password_candidate "$env_password"
    fi

    if [ -f ".config/db_credentials.txt" ]; then
        config_password=$(grep "数据库ROOT密码:" .config/db_credentials.txt | cut -d':' -f2 | tr -d ' ')
        add_db_password_candidate "$config_password"
    fi

    if [ -n "$mariadb_container" ]; then
        container_password=$(sudo docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$mariadb_container" 2>/dev/null | grep '^MARIADB_ROOT_PASSWORD=' | tail -n 1 | cut -d'=' -f2- | tr -d '\r')
        add_db_password_candidate "$container_password"
    fi

    if [ ${#candidates[@]} -eq 0 ]; then
        return 1
    fi

    if [ -n "$mariadb_container" ]; then
        for candidate in "${candidates[@]}"; do
            if sudo docker exec -e POETIZE_DB_ROOT_PASSWORD="$candidate" "$mariadb_container" sh -lc 'mariadb -u root -p"$POETIZE_DB_ROOT_PASSWORD" -N -e "SELECT 1" >/dev/null 2>&1'; then
                printf "%s\n" "$candidate"
                return 0
            fi
        done

        warning "未能验证数据库ROOT密码，优先使用当前项目配置继续尝试"
    fi

    printf "%s\n" "${candidates[0]}"
}

SQL_EXEC_LAST_ERROR=""

execute_sql_file_in_container() {
    local mariadb_container="$1"
    local db_root_password="$2"
    local sql_file="$3"
    local error_file=""

    SQL_EXEC_LAST_ERROR=""
    error_file=$(mktemp 2>/dev/null || printf "/tmp/poetize-sql-error-%s.log" "$$")

    if sudo docker exec -i -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" \
        sh -lc 'mariadb -u root -p"$POETIZE_DB_ROOT_PASSWORD" poetize' < "$sql_file" 2>"$error_file"; then
        rm -f "$error_file"
        return 0
    fi

    if [ -f "$error_file" ]; then
        SQL_EXEC_LAST_ERROR=$(tail -n 20 "$error_file" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | sed 's/^ //; s/ $//')
        rm -f "$error_file"
    fi

    return 1
}

resolve_redis_password() {
    local config_password=""
    local env_password=""

    if [ -f ".config/redis_config.txt" ]; then
        config_password=$(grep "Redis密码:" .config/redis_config.txt | head -n 1 | cut -d':' -f2- | tr -d ' \r')
        if [ -n "$config_password" ]; then
            printf "%s\n" "$config_password"
            return 0
        fi
    fi

    if [ -f ".env" ]; then
        env_password=$(grep -E '^REDIS_PASSWORD=' .env 2>/dev/null | tail -n 1 | cut -d'=' -f2- | tr -d '\r')
        if [ -n "$env_password" ]; then
            printf "%s\n" "$env_password"
            return 0
        fi
    fi

    if [ -n "$REDIS_PASSWORD" ]; then
        printf "%s\n" "$REDIS_PASSWORD"
        return 0
    fi

    if [ -n "$REDIS_PWD" ]; then
        printf "%s\n" "$REDIS_PWD"
        return 0
    fi

    printf "%s\n" "poetize_redis_2025"
}

clear_volume_contents() {
    local volume_name="$1"
    local volume_label="$2"

    if [ -z "$volume_name" ]; then
        return 1
    fi

    info "清空${volume_label} volume 现有数据: $volume_name"
    if sudo docker run --rm -v "$volume_name":/data alpine sh -c 'rm -rf /data/* /data/.[!.]* /data/..?* 2>/dev/null || true'; then
        success "${volume_label} volume 清理完成"
        return 0
    fi

    warning "${volume_label} volume 清理失败，后续将继续尝试恢复"
    return 1
}

wait_for_redis_ready() {
    local redis_container="$1"
    local redis_password="$2"
    local max_attempts=30
    local attempt=1

    if [ -z "$redis_container" ]; then
        return 1
    fi

    while [ $attempt -le $max_attempts ]; do
        if sudo docker exec -e POETIZE_REDIS_PASSWORD="$redis_password" "$redis_container" sh -lc '
            if [ -n "$POETIZE_REDIS_PASSWORD" ]; then
                redis-cli -a "$POETIZE_REDIS_PASSWORD" --no-auth-warning ping >/dev/null 2>&1
            else
                redis-cli ping >/dev/null 2>&1
            fi
        '; then
            return 0
        fi
        sleep 1
        attempt=$((attempt + 1))
    done

    return 1
}

cleanup_restored_redis_cache() {
    local redis_container="$1"
    local redis_password="$2"
    local pattern=""
    local patterns=(
        "poetize:webinfo"
        "poetize:config:*"
        "poetize:sort:article:list"
        "poetize:article:list:*"
        "poetize:user:article:list:*"
        "poetize:label:list:*"
        "poetize:article:hot"
        "poetize:search:article:*"
        "poetize:admin"
        "poetize:family:list"
        "poetize:admire:list"
    )

    if [ -z "$redis_container" ]; then
        return 0
    fi

    info "清理可重建的Redis缓存，确保恢复后优先使用数据库中的最新数据..."

    for pattern in "${patterns[@]}"; do
        case "$pattern" in
            *"*"*|*"?"*|*"["*)
                sudo docker exec \
                    -e POETIZE_REDIS_PASSWORD="$redis_password" \
                    -e POETIZE_REDIS_PATTERN="$pattern" \
                    "$redis_container" sh -lc '
                        redis_cmd() {
                            if [ -n "$POETIZE_REDIS_PASSWORD" ]; then
                                redis-cli -a "$POETIZE_REDIS_PASSWORD" --no-auth-warning "$@"
                            else
                                redis-cli "$@"
                            fi
                        }
                        redis_cmd --scan --pattern "$POETIZE_REDIS_PATTERN" | while IFS= read -r key; do
                            [ -n "$key" ] && redis_cmd del "$key" >/dev/null
                        done
                    ' >/dev/null 2>&1 || warning "清理Redis缓存模式失败: $pattern"
                ;;
            *)
                sudo docker exec \
                    -e POETIZE_REDIS_PASSWORD="$redis_password" \
                    -e POETIZE_REDIS_KEY="$pattern" \
                    "$redis_container" sh -lc '
                        if [ -n "$POETIZE_REDIS_PASSWORD" ]; then
                            redis-cli -a "$POETIZE_REDIS_PASSWORD" --no-auth-warning del "$POETIZE_REDIS_KEY" >/dev/null
                        else
                            redis-cli del "$POETIZE_REDIS_KEY" >/dev/null
                        fi
                    ' >/dev/null 2>&1 || warning "清理Redis缓存键失败: $pattern"
                ;;
        esac
    done

    success "Redis可重建缓存清理完成"
}

# 创建完整数据备份
create_full_backup() {
    info "开始创建完整数据备份..."
    
    # 创建备份目录（放在项目目录外的安全位置）
    local backup_timestamp=$(date +%Y%m%d_%H%M%S)
    local project_name="${POETIZE_PROJECT_NAME:-$(basename "$(pwd)")}"
    BACKUP_PROJECT_NAME="$project_name"
    BACKUP_DIR="/tmp/poetize_update_backup_${project_name}_${backup_timestamp}"
    mkdir -p "$BACKUP_DIR"
    
    info "备份目录: $BACKUP_DIR"
    info "备份位置: 系统临时目录（不会被卸载删除）"
    
    # 执行实际备份操作
    perform_backup_operations "$BACKUP_DIR"
    
    success "完整数据备份创建完成: $BACKUP_DIR"
    return 0
}

# 用户手动备份数据
backup_data() {
    local backup_path="$1"
    
    # 查找项目目录
    find_project_dir
    
    # 如果未指定备份路径，使用默认路径
    if [ -z "$backup_path" ]; then
        local backup_timestamp=$(date +%Y%m%d_%H%M%S)
        local project_name=$(basename "$(pwd)")
        backup_path="/tmp/poetize_backup_${project_name}_${backup_timestamp}"
        info "未指定备份路径，使用默认路径: $backup_path"
    fi
    
    # 创建备份目录
    mkdir -p "$backup_path"
    
    info "开始备份数据到: $backup_path"
    
    # 执行实际备份操作
    if perform_backup_operations "$backup_path"; then
        success "数据备份完成: $backup_path"
        info "备份内容包含:"
        info "  - 数据库数据"
        info "  - 数据库凭据"
        info "  - Python配置文件"
        info "  - 用户上传文件"
        info "  - Redis缓存数据"
        info "  - 域名和端口配置"
        printf "\n"
        info "恢复数据时请使用以下命令:"
        printf "  ${CYAN}poetize -restore $backup_path${NC}\n"
    else
        error "数据备份失败"
        return 1
    fi
}

# 执行实际备份操作的通用函数
perform_backup_operations() {
    local backup_dir="$1"
    
    # 1. 备份数据库凭据
    info "备份数据库凭据..."
    if [ -f ".config/db_credentials.txt" ]; then
        mkdir -p "$backup_dir/.config"
        cp ".config/db_credentials.txt" "$backup_dir/.config/"
        success "数据库凭据备份完成"
    else
        warning "数据库凭据文件不存在，跳过备份"
    fi
    
    # 3. 备份数据库
    info "备份数据库数据..."
    local mariadb_container=$(resolve_compose_container_name "mysql" 2>/dev/null || true)
    local db_root_password=""
    if [ -n "$mariadb_container" ]; then
        db_root_password=$(resolve_db_root_password "$mariadb_container" 2>/dev/null || true)
    fi
    if [ -n "$mariadb_container" ] && [ -n "$db_root_password" ]; then
        info "使用MariaDB容器: $mariadb_container"
        if sudo docker exec -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" sh -lc 'mariadb-dump -u root -p"$POETIZE_DB_ROOT_PASSWORD" --single-transaction --routines --triggers --databases poetize' > "$backup_dir/poetry.sql"; then
            success "数据库备份完成"
        else
            error "数据库备份失败"
            return 1
        fi
    else
        warning "MariaDB容器未运行或数据库密码未找到，跳过数据库备份"
    fi
    
    # 4. 备份Python配置文件
    info "备份Python配置文件..."
    if [ -d "py/data" ]; then
        mkdir -p "$backup_dir/py"
        cp -r "py/data" "$backup_dir/py/"
        success "Python配置文件备份完成"
    else
        warning "Python配置目录不存在，跳过备份"
    fi
    
    # 5. 备份用户上传文件
    info "备份用户上传文件..."
    local actual_uploads_volume=$(resolve_service_volume_name "nginx" "/usr/share/nginx/html/uploads" "poetize_uploads" 2>/dev/null || true)
    if [ -z "$actual_uploads_volume" ]; then
        actual_uploads_volume=$(resolve_service_volume_name "java-backend" "/app/static" "poetize_uploads" 2>/dev/null || true)
    fi
    if [ -n "$actual_uploads_volume" ]; then
        info "找到用户上传文件volume: $actual_uploads_volume"
        # 检查volume中是否有数据
        if sudo docker run --rm -v "$actual_uploads_volume":/data alpine sh -c "[ -d /data/. ] && [ \"\$(ls -A /data/. 2>/dev/null)\" ]"; then
            info "导出用户上传文件..."
            if sudo docker run --rm -v "$actual_uploads_volume":/data -v "$backup_dir":/backup alpine tar -czf "/backup/uploads_backup.tar.gz" -C /data .; then
                success "用户上传文件备份完成"
            else
                warning "用户上传文件备份失败"
            fi
        else
            info "用户上传文件volume为空，跳过备份"
        fi
    else
        info "未找到用户上传文件volume，跳过备份"
    fi
    
    # 6. 备份Redis数据
    info "备份Redis数据..."
    local actual_redis_volume=$(resolve_service_volume_name "redis" "/data" "redis_data" 2>/dev/null || true)
    if [ -n "$actual_redis_volume" ]; then
        info "找到Redis数据volume: $actual_redis_volume"
        # 检查volume中是否有数据
        if sudo docker run --rm -v "$actual_redis_volume":/data alpine sh -c "[ -d /data/. ] && [ \"\$(ls -A /data/. 2>/dev/null)\" ]"; then
            info "导出Redis数据..."
            if sudo docker run --rm -v "$actual_redis_volume":/data -v "$backup_dir":/backup alpine tar -czf "/backup/redis_backup.tar.gz" -C /data .; then
                success "Redis数据备份完成"
            else
                warning "Redis数据备份失败"
            fi
        else
            info "Redis数据volume为空，跳过备份"
        fi
    else
        info "未找到Redis数据volume，跳过备份"
    fi

    # 7. 备份nginx配置中的域名信息
    info "备份域名配置信息..."
    local extracted_domains=$(extract_domains_from_nginx_config 2>/dev/null || echo "")
    if [ -n "$extracted_domains" ]; then
        echo "$extracted_domains" > "$backup_dir/domains.txt"
        success "域名配置备份完成: $extracted_domains"
    else
        info "未找到域名配置，跳过域名备份"
    fi
    
    # 8. 备份端口配置
    info "备份端口配置..."
    local http_port=""
    
    # 优先从 .env 文件读取端口配置
    if [ -f ".env" ] && type read_env_config &>/dev/null; then
        http_port=$(read_env_config "HTTP_PORT" "")
        if [ -n "$http_port" ] && [ "$http_port" != "80" ]; then
            echo "$http_port" > "$backup_dir/http_port.txt"
            success "HTTP端口配置备份完成 (从 .env): $http_port"
        else
            info "使用默认80端口"
        fi
    elif [ -f "docker-compose.yml" ]; then
        # 回退方案：从 docker-compose.yml 提取HTTP端口配置
        http_port=$(grep -E '^\s*-\s*["'\'']*[0-9]+:80' docker-compose.yml 2>/dev/null | head -1 | grep -oE '[0-9]+' | head -1)
        if [ -n "$http_port" ]; then
            echo "$http_port" > "$backup_dir/http_port.txt"
            success "HTTP端口配置备份完成: $http_port"
        else
            info "使用默认80端口"
        fi
    fi
    
    # 备份 .env 文件（如果存在）
    if [ -f ".env" ]; then
        cp ".env" "$backup_dir/.env"
        success ".env 配置文件备份完成"
    fi
    
    # 9. 创建备份清单
    info "创建备份清单..."
    cat > "$backup_dir/backup_manifest.txt" << EOF
POETIZE系统备份清单
备份时间: $(date '+%Y-%m-%d %H:%M:%S')
备份目录: $backup_dir
项目目录: $(pwd)

备份内容:
- 数据库数据: poetry.sql
- 数据库凭据: .config/db_credentials.txt
- Python配置: py/data/
- 用户上传文件: uploads_backup.tar.gz
- Redis缓存数据: redis_backup.tar.gz
- 域名配置: domains.txt
- 端口配置: http_port.txt

恢复命令: poetize -restore $backup_dir
EOF
    
    return 0
}

# 从nginx配置中提取域名
extract_domains_from_nginx_config() {
    local nginx_config_file="docker/nginx/default.https.conf"
    local domains=""
    
    if [ -f "$nginx_config_file" ]; then
        info "从nginx配置文件中提取域名..." >&2
        # 提取server_name行中的域名，排除example.com
        domains=$(extract_server_names_from_nginx_file "$nginx_config_file")
        
        if [ -n "$domains" ]; then
            info "提取到域名: $domains" >&2
            echo "$domains"
            return 0
        else
            warning "未找到有效域名或只有默认域名" >&2
            return 1
        fi
    else
        warning "nginx配置文件不存在: $nginx_config_file" >&2
        return 1
    fi
}


# 检测是否为国内环境
is_china_environment() {
    # 方法1: 检测网络连通性
    if command -v curl &>/dev/null; then
        # 检测是否能访问Google（国内通常被屏蔽）
        if ! curl -s --connect-timeout 3 --max-time 5 "https://www.google.com" >/dev/null 2>&1; then
            # 无法访问Google，再检测是否能访问国内镜像源
            if curl -s --connect-timeout 3 --max-time 5 "http://mirrors.aliyun.com" >/dev/null 2>&1; then
                return 0  # 无法访问Google但能访问阿里云镜像，判断为国内环境
            fi
        fi
    elif command -v ping &>/dev/null; then
        # 如果没有curl，使用ping检测
        if ! ping -c 1 -W 3 www.google.com >/dev/null 2>&1; then
            # 无法ping通Google，再检测国内镜像源
            if ping -c 1 -W 3 mirrors.aliyun.com >/dev/null 2>&1; then
                return 0  # 无法ping通Google但能ping通阿里云镜像，判断为国内环境
        fi
      fi
    fi
    
    # 方法2: 检测IP地址归属
    local ip_check_result=""
    if command -v curl &>/dev/null; then
        # 尝试获取公网IP并检测归属地
        ip_check_result=$(curl -s --connect-timeout 5 --max-time 10 "http://ip-api.com/json" 2>/dev/null | grep -o '"country":"China"' || echo "")
        if [[ -n "$ip_check_result" ]]; then
            return 0  # 是国内环境
        fi
    fi
    
    # 方法3: 检测时区
    if [[ -f /etc/timezone ]]; then
        if grep -q "Asia/Shanghai\|Asia/Chongqing" /etc/timezone; then
            return 0  # 是国内环境
        fi
    fi
    
    # 方法4: 检测locale
    if [[ "$LANG" =~ zh_CN || "$LC_ALL" =~ zh_CN ]]; then
        return 0  # 是国内环境
    fi
    
    return 1  # 不是国内环境
}

# 解析更新目标的仓库地址和版本
resolve_update_source() {
    local is_china_env=false
    RESOLVED_GIT_URL=""
    RESOLVED_TARGET_VERSION=""
    RESOLVED_BRANCH_OPT=""

    if is_china_environment; then
        is_china_env=true
    fi

    if [ "$is_china_env" = true ]; then
        RESOLVED_GIT_URL="https://gitee.com/leapya/poetize.git"
    else
        RESOLVED_GIT_URL="https://github.com/LeapYa/awesome-poetize-open.git"
    fi

    if [ -n "$UPDATE_VERSION" ]; then
        RESOLVED_TARGET_VERSION="$UPDATE_VERSION"
        info "使用指定版本: $RESOLVED_TARGET_VERSION"
    elif [ "$USE_LATEST_TAG" = "true" ]; then
        info "获取最新稳定版本..."
        local release_api_url=""
        if [ "$is_china_env" = true ]; then
            release_api_url="https://gitee.com/api/v5/repos/leapya/poetize/releases/latest"
            RESOLVED_TARGET_VERSION=$(curl -fsSL "$release_api_url" 2>/dev/null | grep -o '"tag_name":"[^"]*"' | head -1 | sed 's/"tag_name":"//;s/"//')
        else
            release_api_url="https://api.github.com/repos/LeapYa/awesome-poetize-open/releases/latest"
            RESOLVED_TARGET_VERSION=$(curl -fsSL "$release_api_url" 2>/dev/null | grep -o '"tag_name": "[^"]*"' | head -1 | sed 's/"tag_name": "//;s/"//')
        fi

        if [ -n "$RESOLVED_TARGET_VERSION" ]; then
            info "使用最新稳定版本: $RESOLVED_TARGET_VERSION"
        else
            warning "无法从 Release API 获取版本，尝试使用 git tags..."
            RESOLVED_TARGET_VERSION=$(git ls-remote --tags "$RESOLVED_GIT_URL" 2>/dev/null | grep -o 'refs/tags/v[0-9.]*$' | sed 's|refs/tags/||' | sort -V | tail -1)
            if [ -n "$RESOLVED_TARGET_VERSION" ]; then
                info "使用最新标签版本: $RESOLVED_TARGET_VERSION"
            else
                warning "无法获取最新版本标签，将使用main分支"
            fi
        fi
    else
        info "使用main分支（最新开发版本）"
    fi

    if [ -n "$RESOLVED_TARGET_VERSION" ]; then
        RESOLVED_BRANCH_OPT="--branch $RESOLVED_TARGET_VERSION"
    fi

    RESOLVED_TARGET_VERSION="${RESOLVED_TARGET_VERSION:-main}"

    return 0
}

# 安装更新流程需要的基础工具
ensure_update_dependencies() {
    if command -v apt-get &>/dev/null; then
        sudo apt-get update && sudo apt-get install -y git curl
    elif command -v yum &>/dev/null; then
        sudo yum install -y git curl
    elif command -v dnf &>/dev/null; then
        sudo dnf install -y git curl
    elif command -v zypper &>/dev/null; then
        sudo zypper install -y git curl
    elif command -v pacman &>/dev/null; then
        sudo pacman -S --needed git curl
    elif command -v apk &>/dev/null; then
        sudo apk add --update-cache git curl
    else
        error '不支持的包管理器，请手动安装git和curl'
        exit 1
    fi
}

# 拉取项目代码
pull_code_on_target() {
    info "拉取项目代码..."

    ensure_update_dependencies
    resolve_update_source

    info "使用仓库地址: $RESOLVED_GIT_URL"

    local target_parent_dir="${POETIZE_PROJECT_PARENT_DIR:-$(pwd)}"
    local target_project_name="${BACKUP_PROJECT_NAME:-${POETIZE_PROJECT_NAME:-awesome-poetize-open}}"
    local target_dir="${target_parent_dir}/${target_project_name}"

    if [ -e "$target_dir" ]; then
        error "更新目标目录仍然存在，已停止以避免在旧目录内再次拉取同名项目: $target_dir"
        error "请先确认旧项目目录是否已删除，再重新执行 poetize -update"
        return 1
    fi

    # 克隆项目
    git clone --depth 1 $RESOLVED_BRANCH_OPT "$RESOLVED_GIT_URL" "$target_dir"
    
    # 检查是否成功
    if [ -d "$target_dir" ] && [ -f "$target_dir/poetize" ]; then
        success "项目代码拉取成功${RESOLVED_TARGET_VERSION:+: $RESOLVED_TARGET_VERSION}"
        cd "$target_dir"
        set_project_context "$target_dir"
        return 0
    else
        error '项目代码拉取失败'
        return 1
    fi
}

# 安装项目中的 poetize 脚本到全局命令
install_poetize_command_from_project() {
    local source_poetize="${1:-poetize}"
    local current_poetize="/usr/local/bin/poetize"

    if [ ! -f "$source_poetize" ]; then
        warning "未找到新版本的poetize脚本，跳过命令更新"
        return 1
    fi

    if [ -f "$current_poetize" ]; then
        sudo cp "$current_poetize" "/usr/local/bin/poetize.backup.$(date +%Y%m%d_%H%M%S)"
    fi

    sudo cp "$source_poetize" "$current_poetize"
    sudo chmod +x "$current_poetize"
    info "已安装单文件 poetize 命令"
    return 0
}

poetize_runtime_matches() {
    local candidate_poetize="${1:-}"
    local installed_poetize="/usr/local/bin/poetize"

    if [ ! -f "$candidate_poetize" ] || [ ! -f "$installed_poetize" ]; then
        return 1
    fi

    cmp -s "$installed_poetize" "$candidate_poetize" || return 1
    return 0
}

# 检查更新流程是否需要先自更新 poetize 命令
ensure_latest_poetize_for_update() {
    local raw_update_arg="${1:-}"
    local current_poetize="/usr/local/bin/poetize"
    local temp_update_dir="/tmp/poetize_self_update_$$"

    if [ "${POETIZE_SKIP_SELF_UPDATE:-false}" = "true" ]; then
        return 0
    fi

    find_project_dir
    ensure_update_dependencies
    resolve_update_source

    info "预拉取目标版本的poetize脚本用于自更新检查..."
    rm -rf "$temp_update_dir"
    if ! git clone --depth 1 $RESOLVED_BRANCH_OPT "$RESOLVED_GIT_URL" "$temp_update_dir" >/dev/null 2>&1; then
        warning "无法预拉取目标版本代码，跳过poetize命令自更新检查"
        return 0
    fi

    if [ ! -f "$temp_update_dir/poetize" ]; then
        warning "目标版本中未找到poetize脚本，跳过命令自更新检查"
        rm -rf "$temp_update_dir"
        return 0
    fi

    if poetize_runtime_matches "$temp_update_dir/poetize"; then
        info "poetize命令已是目标版本，继续执行更新"
        rm -rf "$temp_update_dir"
        return 0
    fi

    info "检测到目标版本的poetize命令有更新，正在先升级升级器本身..."
    install_poetize_command_from_project "$temp_update_dir/poetize" || {
        rm -rf "$temp_update_dir"
        error "poetize命令自动更新失败"
        exit 1
    }
    rm -rf "$temp_update_dir"

    success "poetize命令已更新，正在切换到新版本继续执行升级"

    if [ -n "$raw_update_arg" ]; then
        exec env POETIZE_SKIP_SELF_UPDATE=true "$current_poetize" -update "$raw_update_arg"
    fi

    exec env POETIZE_SKIP_SELF_UPDATE=true "$current_poetize" -update
}

# 检查并更新poetize命令本身
update_poetize_command() {
    find_project_dir

    info "检查poetize命令是否需要更新..."

    if [ ! -f "poetize" ]; then
        warning "未找到新版本的poetize脚本，跳过命令更新"
        return 0
    fi

    if poetize_runtime_matches "poetize"; then
        info "poetize命令已是最新版本"
        return 0
    fi

    info "发现poetize命令需要更新，正在安装新版本..."
    install_poetize_command_from_project "poetize" || {
        error "poetize命令更新失败"
        exit 1
    }

    success "poetize命令已更新到最新版本"
    info "后续执行将直接使用新版本poetize命令"
}

# 执行额外的SQL脚本（除了poetry.sql之外的新增表脚本）
# 支持版本跟踪：如果 db_migrations 表存在，只执行未记录的脚本
execute_additional_sql_scripts() {
    info "检查并执行新增的SQL脚本..."
    
    # 获取数据库连接信息
    local mariadb_container=$(resolve_compose_container_name "mysql" 2>/dev/null || true)
    local db_root_password=""
    if [ -n "$mariadb_container" ]; then
        db_root_password=$(resolve_db_root_password "$mariadb_container" 2>/dev/null || true)
    fi
    
    if [ -z "$db_root_password" ]; then
        warning "无法获取数据库密码，跳过额外SQL脚本执行"
        return 1
    fi

    info "额外SQL脚本目标数据库容器: $mariadb_container"
    
    # 等待数据库容器启动
    info "等待数据库容器启动..."
    sleep 15
    
    if [ -z "$mariadb_container" ]; then
        warning "未找到MariaDB容器，跳过额外SQL脚本执行"
        return 1
    fi
    
    # 查找poetize-server/sql目录下除poetry.sql和poetry_old.sql外的所有.sql文件
    if [ -d "poetize-server/sql" ]; then
        local sql_files=$(find poetize-server/sql -name "*.sql" -not -name "poetry.sql" -not -name "poetry_old.sql" -type f | sort)
        
        if [ -z "$sql_files" ]; then
            info "未找到需要执行的额外SQL脚本"
            return 0
        fi
        
        # 检查 db_migrations 表是否存在
        local has_migrations_table=false
        if sudo docker exec -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" sh -lc 'mariadb -u root -p"$POETIZE_DB_ROOT_PASSWORD" poetize -N -e "SELECT 1 FROM db_migrations LIMIT 1"' 2>/dev/null | grep -q "1"; then
            has_migrations_table=true
            info "检测到版本跟踪表，将只执行未记录的脚本"
        fi
        
        # 统计待执行脚本数量
        local total_count=0
        local skip_count=0
        local exec_count=0
        local fail_count=0
        
        # 第一遍：统计
        while IFS= read -r sql_file; do
            [ -z "$sql_file" ] && continue
            total_count=$((total_count + 1))
        done <<< "$sql_files"
        
        info "发现 $total_count 个SQL脚本"
        
        # 第二遍：执行
        while IFS= read -r sql_file; do
            [ -z "$sql_file" ] && continue
            [ ! -f "$sql_file" ] && continue
            
            # 提取版本号（文件名不含路径和.sql后缀）
            local version=$(basename "$sql_file" .sql)
            
            # 如果有版本跟踪表，检查是否已执行
            if [ "$has_migrations_table" = true ]; then
                local already_executed=$(sudo docker exec -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" sh -lc "mariadb -u root -p\"\$POETIZE_DB_ROOT_PASSWORD\" poetize -N -e \"SELECT COUNT(*) FROM db_migrations WHERE version='$version' AND success=1\"" 2>/dev/null | tr -d '[:space:]')
                if [ "$already_executed" = "1" ]; then
                    skip_count=$((skip_count + 1))
                    info "跳过: $sql_file (已执行)"
                    continue
                fi
            fi
            
            # 执行SQL脚本
            info "执行SQL脚本: $sql_file"
            local start_time=$(date +%s%3N 2>/dev/null || date +%s)
            
            if execute_sql_file_in_container "$mariadb_container" "$db_root_password" "$sql_file"; then
                local end_time=$(date +%s%3N 2>/dev/null || date +%s)
                local exec_time=$((end_time - start_time))
                
                # 如果刚执行的是版本表初始化脚本，重新检查表是否存在
                if [ "$version" = "000000000000" ] && [ "$has_migrations_table" = false ]; then
                    if sudo docker exec -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" sh -lc 'mariadb -u root -p"$POETIZE_DB_ROOT_PASSWORD" poetize -N -e "SELECT 1 FROM db_migrations LIMIT 1"' 2>/dev/null | grep -q "1"; then
                        has_migrations_table=true
                        info "版本跟踪表已创建，后续脚本执行将被记录"
                    fi
                fi
                
                # 记录到版本表（如果表存在）
                if [ "$has_migrations_table" = true ]; then
                    sudo docker exec -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" sh -lc "mariadb -u root -p\"\$POETIZE_DB_ROOT_PASSWORD\" poetize -e \"INSERT IGNORE INTO db_migrations (version, description, execution_time_ms, success) VALUES ('$version', '自动执行', $exec_time, 1)\"" 2>/dev/null
                fi
                
                success "SQL脚本执行成功: $sql_file (${exec_time}ms)"
                exec_count=$((exec_count + 1))
            else
                # 记录失败（如果表存在）
                if [ "$has_migrations_table" = true ]; then
                    sudo docker exec -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" sh -lc "mariadb -u root -p\"\$POETIZE_DB_ROOT_PASSWORD\" poetize -e \"INSERT IGNORE INTO db_migrations (version, description, success) VALUES ('$version', '执行失败', 0)\"" 2>/dev/null
                fi
                
                warning "SQL脚本执行失败: $sql_file"
                if [ -n "$SQL_EXEC_LAST_ERROR" ]; then
                    warning "数据库错误: $SQL_EXEC_LAST_ERROR"
                fi
                fail_count=$((fail_count + 1))
            fi
        done <<< "$sql_files"
        
        # 输出统计信息
        info "SQL脚本执行统计: 总计=$total_count, 执行=$exec_count, 跳过=$skip_count, 失败/已存在=$fail_count"
        success "额外SQL脚本执行完成"
    else
        warning "poetize-server/sql目录不存在，跳过额外SQL脚本执行"
    fi
}

# 重新安装最新系统
reinstall_latest_system() {
    info "开始重新安装最新版本的POETIZE系统..."

    # 拉取项目
    pull_code_on_target
    
    # 恢复数据库
    cp "$BACKUP_DIR/poetry.sql" "poetize-server/sql/poetry.sql"
    # 恢复Python文件配置
    if [ -d "$BACKUP_DIR/.config" ]; then
        cp -r "$BACKUP_DIR/.config" ./
    fi

    # 更新路径需要在 install 前写入版本信息，供前端构建时注入 APP_VERSION
    local deploy_version="${RESOLVED_TARGET_VERSION:-main}"
    local app_version="${RESOLVED_TARGET_VERSION:-dev}"
    mkdir -p ".config"
    cat > ".config/version.txt" << EOF
# POETIZE 部署版本信息
VERSION=${deploy_version}
DEPLOY_TIME=$(date '+%Y-%m-%d %H:%M:%S')
DEPLOY_SOURCE=$([ -n "$RESOLVED_TARGET_VERSION" ] && echo "tag" || echo "main")
EOF
    info "版本信息已保存到 .config/version.txt"

    # 恢复 .env 文件：优先从备份恢复（保留用户的密码、AES key 等凭据）
    if [ -f "$BACKUP_DIR/.env" ]; then
        cp "$BACKUP_DIR/.env" ".env"
        success "已从备份恢复 .env 配置文件（保留原有凭据）"
    elif [ ! -f ".env" ] && [ -f ".env.example" ]; then
        cp ".env.example" ".env"
        success "配置文件已从模板创建: .env"
    fi

    if [ -f ".env" ]; then
        if grep -q "^APP_VERSION=" ".env" 2>/dev/null; then
            local temp_env=".env.tmp.$$"
            awk -v value="$app_version" '
                /^APP_VERSION=/ { print "APP_VERSION=" value; next }
                { print }
            ' ".env" > "$temp_env" && mv "$temp_env" ".env"
        else
            printf "\nAPP_VERSION=%s\n" "$app_version" >> ".env"
        fi
        info "已同步 APP_VERSION=$app_version 到 .env"
    else
        warning "未找到 .env 和 .env.example，跳过 APP_VERSION 同步"
    fi

    # 构建poetize系统安装命令
    local domains=""
    local backup_domains_file="$BACKUP_DIR/domains.txt"
    
    # 从备份中读取域名，如果没有备份则从当前配置中提取
    if [ -f "$backup_domains_file" ]; then
        domains=$(cat "$backup_domains_file" 2>/dev/null)
        info "从备份中读取到域名: $domains"
    else
        domains=$(extract_domains_from_nginx_config 2>/dev/null || echo "")
        if [ -n "$domains" ]; then
            info "从当前配置中提取到域名: $domains"
        fi
    fi
    
    # 构建安装命令
    local deploy_cmd=""
    if [ -f "deploy.sh" ]; then
        info "检测到 deploy.sh，当前版本为旧版结构，使用 deploy.sh 进行安装"
        deploy_cmd="sudo chmod +x deploy.sh && sudo POETIZE_UPDATE_MODE=true ./deploy.sh"
    elif [ -f "poetize" ]; then
        deploy_cmd="sudo chmod +x poetize && sudo POETIZE_UPDATE_MODE=true ./poetize install"
    else
        error "无法找到安装脚本 (poetize 或 deploy.sh)，系统可能已损坏"
        return 1
    fi
    
    if [ -n "$domains" ]; then
        info "使用域名进行自动安装..."
        
        # 从备份中读取端口配置
        local http_port=""
        local backup_port_file="$BACKUP_DIR/http_port.txt"
        if [ -f "$backup_port_file" ]; then
            http_port=$(cat "$backup_port_file" 2>/dev/null | tr -d '[:space:]')
            if [ -n "$http_port" ] && [ "$http_port" != "80" ]; then
                info "从备份中读取到HTTP端口: $http_port"
            else
                http_port=""
            fi
        else
            info "未找到端口配置备份，将使用默认80端口"
        fi
        
        # 为每个域名添加-d参数（支持 域名:端口 格式）
        for domain in $domains; do
            if [ -n "$http_port" ] && [ "$http_port" != "80" ]; then
                # 为域名添加自定义端口
                deploy_cmd="$deploy_cmd -d ${domain}:${http_port}"
                info "使用域名和端口: ${domain}:${http_port}"
            else
                deploy_cmd="$deploy_cmd -d $domain"
                info "使用域名: $domain"
            fi
        done
        info "完整安装命令: $deploy_cmd"
    else
        info "未找到域名配置，将使用交互式域名输入"
    fi
    
    # 设置更新模式标志，防止安装流程中的 mark_all_migrations_as_executed 误标记迁移脚本
    export POETIZE_UPDATE_MODE=true

    # 执行完整安装命令
    eval "$deploy_cmd"
    
    success "最新版本系统安装完成"
    return 0
}

# 恢复完整备份
restore_full_backup() {
    info "开始恢复用户数据和配置..."

    # 检查全局变量BACKUP_DIR是否有效
    if [ -z "$BACKUP_DIR" ] || [ ! -d "$BACKUP_DIR" ]; then
        error "备份目录无效或不存在: $BACKUP_DIR"
        return 1
    fi

    local latest_backup="$BACKUP_DIR"
    info "使用备份目录: $latest_backup"

    # 执行实际恢复操作，传入false表示恢复数据库凭据（用于更新流程）
    if perform_restore_operations "$latest_backup" "false"; then
        return 0
    fi

    return 1
}

# 用户手动恢复数据
restore_data() {
    local backup_path="$1"

    # 查找项目目录
    find_project_dir

    local project_name="${POETIZE_PROJECT_NAME:-$(basename "$(pwd)")}"
    # 如果未指定备份路径，查找最新的备份目录
    if [ -z "$backup_path" ]; then
        info "未指定备份路径，正在查找最新的备份目录..."
        
        # 查找/tmp目录中的poetize备份目录
        local latest_backup=$(find /tmp -maxdepth 1 -type d -iname "poetize_update_backup_${project_name}*" -printf "%T@ %p\n" 2>/dev/null | sort -n | tail -1 | cut -d' ' -f2-)
        
        if [ -z "$latest_backup" ]; then
            error "未找到任何备份目录"
            printf "\n"
            printf "${YELLOW}使用方法:${NC}\n"
            printf "  poetize -restore [备份路径]\n"
            printf "\n"
            printf "${YELLOW}示例:${NC}\n"
            printf "  poetize -restore                    # 恢复最新备份\n"
            printf "  poetize -restore /tmp/poetize_update_backup_${project_name}_20231201_120000\n"
            printf "\n"
            return 1
        fi
        
        backup_path="$latest_backup"
        info "找到最新备份目录: $backup_path"
    fi
    
    # 检查备份路径是否存在
    if [ ! -d "$backup_path" ]; then
        error "备份路径不存在: $backup_path"
        return 1
    fi
    
    # 显示备份信息
    if [ -f "$backup_path/backup_manifest.txt" ]; then
        info "备份信息:"
        cat "$backup_path/backup_manifest.txt"
        printf "\n"
    else
        warning "未找到备份清单文件，继续恢复操作"
    fi
    
    # 确认恢复操作
    printf "${RED}警告: 恢复操作将覆盖当前数据！${NC}\n"
    printf "\n"
    read -rp "确认从 $backup_path 恢复数据？(y/N): " confirm_restore
    case "$confirm_restore" in
        [Yy]|[Yy][Ee][Ss])
            info "用户确认，开始恢复数据..."
            ;;
        *)
            info "用户取消，退出恢复"
            return 0
            ;;
    esac
    
    # 执行实际恢复操作，传入true表示跳过数据库凭据恢复
    if perform_restore_operations "$backup_path" "true"; then
        success "数据恢复完成"
        info "建议重启服务以确保所有更改生效:"
        printf "  ${CYAN}poetize -restart${NC}\n"
    else
        error "数据恢复失败"
        return 1
    fi
}

# 执行实际恢复操作的通用函数
perform_restore_operations() {
    local backup_dir="$1"
    local skip_db_credentials="${2:-false}"  # 默认为false，即恢复数据库凭据
    local runtime_containers=()
    local app_containers_to_resume=()
    local service_name=""
    local container_name=""
    local mariadb_container=""
    local redis_container=""
    local db_root_password=""
    local redis_password=""

    info "开始从 $backup_dir 恢复数据..."

    # 在恢复前暂停会持续写入缓存的运行时服务，避免新安装默认数据覆盖恢复结果
    local runtime_service_names=("nginx" "java-backend" "prerender-worker" "redis")
    if project_requires_python_backend; then
        runtime_service_names=("nginx" "java-backend" "python-backend" "prerender-worker" "redis")
    fi

    for service_name in "${runtime_service_names[@]}"; do
        container_name=$(resolve_compose_container_name "$service_name" 2>/dev/null || true)
        if [ -n "$container_name" ]; then
            runtime_containers+=("$container_name")
            if [ "$service_name" = "redis" ]; then
                redis_container="$container_name"
            fi
        fi
    done

    if [ ${#runtime_containers[@]} -gt 0 ]; then
        info "暂停运行时服务，防止恢复期间写入默认缓存..."
        if sudo docker stop "${runtime_containers[@]}" >/dev/null 2>&1; then
            success "运行时服务已暂停"
        else
            warning "部分运行时服务暂停失败，恢复流程将继续执行"
        fi
    fi

    # 1. 恢复数据库凭据
    if [ "$skip_db_credentials" = "true" ]; then
        info "跳过数据库凭据恢复（保持当前配置）"
    else
        info "恢复数据库凭据..."
        if [ -f "$backup_dir/.config/db_credentials.txt" ]; then
            mkdir -p ".config"
            cp "$backup_dir/.config/db_credentials.txt" ".config/"
            success "数据库凭据恢复完成"
        else
            warning "备份中未找到数据库凭据文件"
        fi
    fi
    
    # 2. 恢复数据库
    # 更新流程中，用户数据已通过 init.sql 在 reinstall 阶段加载，无需重复导入
    if [ "${POETIZE_UPDATE_MODE:-false}" = "true" ]; then
        info "更新模式：数据库已通过 init.sql 加载，跳过重复恢复"
    elif [ -f "$backup_dir/poetry.sql" ]; then
        mariadb_container=$(resolve_compose_container_name "mysql" 2>/dev/null || true)
        if [ -n "$mariadb_container" ]; then
            db_root_password=$(resolve_db_root_password "$mariadb_container" 2>/dev/null || true)
        fi
        
        if [ -n "$db_root_password" ]; then
            if [ -n "$mariadb_container" ]; then
                info "使用MariaDB容器: $mariadb_container"
                if sudo docker exec -i -e POETIZE_DB_ROOT_PASSWORD="$db_root_password" "$mariadb_container" sh -lc 'mariadb -u root -p"$POETIZE_DB_ROOT_PASSWORD" poetize' < "$backup_dir/poetry.sql"; then
                    success "数据库恢复完成"
                else
                    error "数据库恢复失败"
                    if [ ${#runtime_containers[@]} -gt 0 ]; then
                        warning "恢复失败，正在尝试重新启动之前暂停的服务..."
                        sudo docker start "${runtime_containers[@]}" >/dev/null 2>&1 || warning "自动恢复服务失败，请手动启动相关容器"
                    fi
                    return 1
                fi
            else
                warning "未找到MariaDB容器，跳过数据库恢复"
            fi
        else
            warning "未找到数据库密码，跳过数据库恢复"
        fi
    else
        warning "备份中未找到数据库文件"
    fi
    
    # 3. 恢复Python配置文件（兼容旧版本）
    if project_requires_python_backend; then
        info "恢复Python配置文件..."
        if [ -d "$backup_dir/py/data" ]; then
            mkdir -p "py"
            cp -r "$backup_dir/py/data" "py/"
            success "Python配置文件恢复完成"
        else
            warning "备份中未找到Python配置文件"
        fi
    else
        info "当前版本无需恢复独立 Python 配置文件"
    fi
    
    # 4. 恢复用户上传文件
    info "恢复用户上传文件..."
    if [ -f "$backup_dir/uploads_backup.tar.gz" ]; then
        local actual_uploads_volume=$(resolve_service_volume_name "nginx" "/usr/share/nginx/html/uploads" "poetize_uploads" 2>/dev/null || true)
        if [ -z "$actual_uploads_volume" ]; then
            actual_uploads_volume=$(resolve_service_volume_name "java-backend" "/app/static" "poetize_uploads" 2>/dev/null || true)
        fi
        if [ -z "$actual_uploads_volume" ]; then
            actual_uploads_volume=$(resolve_project_volume_name "poetize_uploads" 2>/dev/null || true)
        fi
        if [ -z "$actual_uploads_volume" ]; then
            local compose_project_name
            compose_project_name=$(get_compose_project_name)
            actual_uploads_volume="${compose_project_name}_poetize_uploads"
            info "创建用户上传文件volume: $actual_uploads_volume"
            sudo docker volume create "$actual_uploads_volume" >/dev/null
        fi

        clear_volume_contents "$actual_uploads_volume" "用户上传文件" || true
        info "恢复到volume: $actual_uploads_volume"
        if sudo docker run --rm -v "$actual_uploads_volume":/data -v "$backup_dir":/backup alpine sh -c "cd /data && tar -xzf /backup/uploads_backup.tar.gz"; then
            success "用户上传文件恢复完成"
        else
            warning "用户上传文件恢复失败"
        fi
    else
        info "备份中未找到用户上传文件"
    fi
    
    # 5. 恢复Redis数据
    info "恢复Redis数据..."
    if [ -f "$backup_dir/redis_backup.tar.gz" ]; then
        local actual_redis_volume=$(resolve_service_volume_name "redis" "/data" "redis_data" 2>/dev/null || true)
        if [ -z "$actual_redis_volume" ]; then
            actual_redis_volume=$(resolve_project_volume_name "redis_data" 2>/dev/null || true)
        fi
        if [ -z "$actual_redis_volume" ]; then
            local compose_project_name
            compose_project_name=$(get_compose_project_name)
            actual_redis_volume="${compose_project_name}_redis_data"
            info "创建Redis数据volume: $actual_redis_volume"
            sudo docker volume create "$actual_redis_volume" >/dev/null
        fi

        clear_volume_contents "$actual_redis_volume" "Redis数据" || true
        info "恢复到volume: $actual_redis_volume"
        if sudo docker run --rm -v "$actual_redis_volume":/data -v "$backup_dir":/backup alpine sh -c "cd /data && tar -xzf /backup/redis_backup.tar.gz"; then
            success "Redis数据恢复完成"
        else
            warning "Redis数据恢复失败"
        fi
    else
        info "备份中未找到Redis数据"
    fi
    
    # 6. 重新启动相关服务并清理可重建缓存
    info "启动相关服务以应用恢复后的配置..."

    if [ -n "$redis_container" ]; then
        info "优先启动Redis服务，准备清理可重建缓存..."
        if sudo docker start "$redis_container" >/dev/null 2>&1; then
            redis_password=$(resolve_redis_password 2>/dev/null || true)
            if wait_for_redis_ready "$redis_container" "$redis_password"; then
                cleanup_restored_redis_cache "$redis_container" "$redis_password"
            else
                warning "Redis未在预期时间内就绪，跳过自动缓存清理"
            fi
        else
            warning "Redis服务启动失败，可能需要手动启动"
        fi
    fi

    local app_service_names=("java-backend" "nginx" "prerender-worker")
    if project_requires_python_backend; then
        app_service_names=("java-backend" "python-backend" "nginx" "prerender-worker")
    fi

    for service_name in "${app_service_names[@]}"; do
        container_name=$(resolve_compose_container_name "$service_name" 2>/dev/null || true)
        if [ -n "$container_name" ]; then
            app_containers_to_resume+=("$container_name")
        fi
    done

    if [ ${#app_containers_to_resume[@]} -gt 0 ]; then
        if sudo docker start "${app_containers_to_resume[@]}" >/dev/null 2>&1; then
            success "相关服务启动完成"
        else
            warning "部分服务启动失败，可能需要手动启动"
        fi
    fi
    
    success "用户数据和配置恢复完成"
    return 0
}

# 主要的update函数
run_update() {
    # 显示更新信息
    printf "\n"
    printf "${GREEN}===========================================${NC}\n"
    printf "${GREEN}    POETIZE 系统全量更新工具 v2.0.0${NC}\n"
    printf "${GREEN}===========================================${NC}\n"
    printf "\n"
    
    # 查找项目目录
    find_project_dir

    # 检测降级操作
    if [ -n "$UPDATE_VERSION" ]; then
        # 读取当前部署版本
        local current_version=""
        if [ -f ".config/version.txt" ]; then
            current_version=$(grep "^VERSION=" .config/version.txt 2>/dev/null | cut -d'=' -f2)
        fi
        
        if [ -n "$current_version" ] && [ "$current_version" != "main" ]; then
            # 比较版本（去掉v前缀，使用sort -V比较）
            local target_v=$(echo "$UPDATE_VERSION" | sed 's/^v//')
            local current_v=$(echo "$current_version" | sed 's/^v//')
            
            # 使用sort -V比较版本
            local lower_version=$(printf "%s\n%s" "$target_v" "$current_v" | sort -V | head -1)
            
            if [ "$lower_version" = "$target_v" ] && [ "$target_v" != "$current_v" ]; then
                error "不支持版本降级操作！"
                printf "\n"
                printf "${YELLOW}当前版本: ${NC}${GREEN}$current_version${NC}\n"
                printf "${YELLOW}目标版本: ${NC}${RED}$UPDATE_VERSION${NC}\n"
                printf "\n"
                printf "${RED}降级可能导致数据库兼容性问题，请使用当前版本或更高版本。${NC}\n"
                printf "\n"
                exit 1
            fi
        fi
    fi

    # 确认操作
    printf "\n"
    printf "${YELLOW}警告：全量更新操作将会：${NC}\n"
    printf "1. 备份当前所有数据和配置\n"
    printf "2. 完全卸载当前POETIZE系统\n"
    printf "3. 重新下载并安装最新版本\n"
    printf "4. 恢复您的数据和配置\n"
    printf "\n"
    printf "${RED}注意：此操作将彻底重建系统！${NC}\n"
    printf "\n"
    
    # 30秒超时自动确认（适用于 CI/CD 环境）
    local confirm_update="y"
    read -t 30 -rp "确认执行全量更新操作？(Y/n，30秒后自动确认): " confirm_update || true
    confirm_update=${confirm_update:-y}
    printf "\n"
    
    case "$confirm_update" in
        [Nn]|[Nn][Oo])
            info "用户取消，退出更新"
            exit 0
            ;;
        *)
            info "开始全量更新..."
            ;;
    esac

    # 执行全量更新步骤
    printf "\n"
    info "开始执行全量更新流程..."

    # 1. 备份数据
    info "步骤 1/4: 创建完整数据备份"
    create_full_backup || {
        error "数据备份失败，终止更新"
        exit 1
    }

    # 2. 卸载当前系统
    info "步骤 2/4: 卸载当前POETIZE系统"
    uninstall_services --skip-confirm || {
        error "系统卸载失败，请手动处理"
        exit 1
    }

    # 3. 重新安装系统
    info "步骤 3/4: 重新安装最新版本"
    reinstall_latest_system || {
        error "系统重新安装失败"
        exit 1
    }

    # 4. 恢复数据
    info "步骤 4/4: 恢复用户数据和配置"
    restore_full_backup || {
        error "数据恢复失败，请手动恢复"
        exit 1
    }

    # 完成
    printf "\n"
    printf "${GREEN}===========================================${NC}\n"
    printf "${GREEN}         全量更新完成！${NC}\n"
    printf "${GREEN}===========================================${NC}\n"
    printf "\n"
    success "POETIZE系统已成功更新到最新版本"
    printf "\n"
    
    # 询问是否删除备份目录
    if [ -n "$BACKUP_DIR" ] && [ -d "$BACKUP_DIR" ]; then
        info "备份目录位置: $BACKUP_DIR"
        printf "\n"
        printf "${YELLOW}是否要删除备份目录？${NC}\n"
        printf "  ${CYAN}y${NC} - 删除备份目录 (释放磁盘空间)\n"
        printf "  ${CYAN}n${NC} - 保留备份目录 (默认选项，30秒后自动选择)\n"
        printf "\n"
        
        # 设置30秒超时，默认为n（保留备份）
        local delete_backup="n"
        read -t 30 -rp "请选择 (y/n，默认n，30秒后自动选择n): " delete_backup || true
        delete_backup=${delete_backup:-n}
        printf "\n"
        case "$delete_backup" in
            [Yy]|[Yy][Ee][Ss])
                info "正在删除备份目录..."
                if rm -rf "$BACKUP_DIR"; then
                    success "备份目录已删除"
                else
                    warning "备份目录删除失败，请手动删除: $BACKUP_DIR"
                fi
                ;;
            *)
                info "保留备份目录: $BACKUP_DIR"
                info "您可以稍后手动删除此目录以释放磁盘空间"
                ;;
        esac
        printf "\n"
    fi
    
    info "建议执行以下命令检查系统状态："
    printf "  ${CYAN}poetize -status${NC}    # 查看服务状态\n"
    printf "\n"
}

# 手动启用 HTTPS
enable_https() {
    find_project_dir

    info "正在检查 HTTPS 启用前置条件..."

    # 检查 nginx 容器是否运行
    if ! sudo docker ps --format '{{.Names}}' | grep -q '^poetize-nginx'; then
        error "poetize-nginx 容器未运行，请先启动服务：poetize -start"
        exit 1
    fi

    # 检查 certbot 容器状态（仅提示，不阻断）
    local certbot_status=$(sudo docker inspect --format='{{.State.Status}}' poetize-certbot 2>/dev/null || echo "not-found")
    if [ "$certbot_status" = "not-found" ] || [ "$certbot_status" = "exited" ]; then
        info "certbot 容器当前状态：$certbot_status"
        warning "如果证书尚未申请，建议先启动 certbot 并等待约 2 分钟："
        printf "  ${CYAN}docker start poetize-certbot && sleep 120${NC}\n"
        printf "\n"
        read -rp "是否继续尝试启用 HTTPS？(y/N): " _confirm_https
        case "$_confirm_https" in
            [Yy]|[Yy][Ee][Ss]) ;;
            *)
                info "已取消"
                return 0
                ;;
        esac
    fi

    info "正在执行 /enable-https.sh ..."
    printf "\n"

    # 确保脚本有执行权限
    sudo docker exec --user root poetize-nginx chmod +x /enable-https.sh 2>/dev/null || true

    if sudo docker exec --user root poetize-nginx /enable-https.sh; then
        printf "\n"
        success "HTTPS 启用成功！"
        info "建议执行以下命令确认服务状态："
        printf "  ${CYAN}poetize -status${NC}\n"
    else
        printf "\n"
        error "HTTPS 启用失败，请检查以下内容："
        printf "  1. 域名 DNS 是否已解析到本服务器\n"
        printf "  2. 服务器 80/443 端口是否对公网开放\n"
        printf "  3. certbot 容器日志：${CYAN}docker logs poetize-certbot${NC}\n"
        printf "  4. nginx 容器日志：${CYAN}docker logs poetize-nginx${NC}\n"
        exit 1
    fi
}

# OAuth 反向代理配置向导
configure_oauth_proxy() {
  find_project_dir
  printf "\n"
  printf "${CYAN}────────────────────────────────────────────────────────────────${NC}\n"
  printf "${GREEN}  OAuth 代理配置向导${NC}\n"
  printf "${CYAN}────────────────────────────────────────────────────────────────${NC}\n"
  printf "${BLUE}用于解决国内服务器无法访问 GitHub/Google/X/Yandex 等海外 OAuth 服务的问题${NC}\n"
  printf "\n"

  # ── 步骤一：在海外 VPS 上配置 Nginx ──────────────────────────────
  printf "${YELLOW}[ 第一步 ] 在海外 VPS 上配置 Nginx 反向代理${NC}\n"
  printf "\n"
  printf "在你的海外 VPS 上部署以下 Nginx 配置（将 auth.example.com 替换为你的实际域名）：\n"
  printf "\n"
  printf "${BLUE}┌─ Nginx 配置 (/etc/nginx/conf.d/oauth-proxy.conf) ──────────────────────────────┐${NC}\n"
  cat <<'__NGINX_CONF__'
server {
    listen 443 ssl http2;
    server_name auth.example.com;   # ← 替换为你的代理域名

    ssl_certificate     /path/to/cert.pem;
    ssl_certificate_key /path/to/key.pem;

    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_set_header Connection "";
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_redirect off;

    # ── GitHub ──
    location = /github/login/oauth/access_token {
        proxy_set_header Host github.com;
        proxy_pass https://github.com/login/oauth/access_token;
    }
    location /github/api/ {
        proxy_set_header Host api.github.com;
        proxy_pass https://api.github.com/;
    }

    # ── Google ──
    location /google/oauth2/ {
        proxy_set_header Host oauth2.googleapis.com;
        proxy_pass https://oauth2.googleapis.com/;
    }
    location = /google/oauth2/v2/userinfo {
        proxy_set_header Host www.googleapis.com;
        proxy_pass https://www.googleapis.com/oauth2/v2/userinfo;
    }

    # ── X (Twitter) ──
    location /x/api/ {
        proxy_set_header Host api.twitter.com;
        proxy_pass https://api.twitter.com/;
    }

    # ── Yandex ──
    location = /yandex/token {
        proxy_set_header Host oauth.yandex.com;
        proxy_pass https://oauth.yandex.com/token;
    }
    location /yandex/login/ {
        proxy_set_header Host login.yandex.ru;
        proxy_pass https://login.yandex.ru/;
    }
}
__NGINX_CONF__
  printf "${BLUE}└───────────────────────────────────────────────────────────────────────────────┘${NC}\n"
  printf "\n"
  printf "${YELLOW}配置要点：${NC}\n"
  printf "  1. 为代理域名申请 SSL 证书（推荐 certbot：certbot --nginx -d auth.example.com）\n"
  printf "  2. 建议在 Nginx 中添加 IP 白名单，仅允许你的国内服务器 IP 访问\n"
  printf "     示例：allow YOUR_SERVER_IP; deny all; （加在 server 块内）\n"
  printf "  3. 验证代理是否正常：\n"
  printf "     ${CYAN}curl https://auth.example.com/github/api/user${NC}\n"
  printf "     （应返回 GitHub API 响应，而非连接失败）\n"
  printf "\n"
  printf "  详细说明：${CYAN}docs/OAuth代理配置说明.md${NC}\n"
  printf "\n"
  read -rp "上述代理服务器已配置完毕？按 Enter 继续，输入 q 退出: " _step1_confirm
  if [[ "$_step1_confirm" =~ ^[Qq]$ ]]; then
    info "已退出 OAuth 代理配置向导"
    return 0
  fi

  # ── 步骤二：填入代理域名 ──────────────────────────────────────────
  printf "\n"
  printf "${YELLOW}[ 第二步 ] 填写代理域名${NC}\n"
  printf "\n"

  if [ ! -f ".env" ]; then
    error "未找到 .env 文件，请先完成安装：poetize install"
    return 1
  fi
  if [ ! -f "lib/config.sh" ]; then
    error "未找到 lib/config.sh，请确认项目完整性"
    return 1
  fi
  source "lib/config.sh"

  local current_domain
  current_domain=$(grep -E '^OAUTH_PROXY_DOMAIN=' .env 2>/dev/null | cut -d= -f2- || true)
  if [ -n "$current_domain" ]; then
    printf "当前配置：${CYAN}%s${NC}\n" "$current_domain"
  else
    printf "当前配置：${YELLOW}（未设置）${NC}\n"
  fi
  printf "\n"
  printf "请输入海外代理域名（格式：https://auth.example.com）\n"
  printf "直接回车保持当前配置不变\n"
  printf "\n"
  local new_domain
  read -rp "代理域名: " new_domain

  # 留空 = 保持不变
  if [ -z "$new_domain" ]; then
    if [ -z "$current_domain" ]; then
      warning "未输入域名，OAuth 代理未配置，退出"
      return 0
    fi
    info "保持当前配置：$current_domain"
    new_domain="$current_domain"
  else
    # 格式校验
    if [[ ! "$new_domain" =~ ^https?:// ]]; then
      printf "\n"
      read -rp "检测到缺少协议前缀，自动补全为 https://${new_domain}？[Y/n]: " _fix
      if [[ ! "$_fix" =~ ^[Nn]$ ]]; then
        new_domain="https://${new_domain}"
      else
        error "请重新运行并输入完整格式（如 https://auth.example.com）"
        return 1
      fi
    fi
    # 去掉末尾斜杠
    new_domain="${new_domain%/}"
    printf "\n"
    printf "将配置代理域名为：${CYAN}%s${NC}\n" "$new_domain"
  fi

  # ── 步骤三：写入 .env 并重启 Java ─────────────────────────────────
  printf "\n"
  printf "${YELLOW}[ 第三步 ] 写入配置并重启 Java 服务${NC}\n"
  printf "\n"

  update_env_var "OAUTH_PROXY_DOMAIN" "$new_domain"
  success "已更新 .env → OAUTH_PROXY_DOMAIN=$new_domain"

  printf "\n"
  info "正在重启 Java 服务以使配置生效..."
  if $DOCKER_COMPOSE_CMD up -d --no-deps --force-recreate java-backend 2>/dev/null; then
    success "Java 服务已重启"
    printf "\n"
    printf "${GREEN}✓ OAuth 代理配置完成！${NC}\n"
    printf "\n"
    printf "  代理域名：${CYAN}%s${NC}\n" "$new_domain"
    printf "\n"
    printf "  后端 OAuth 请求将通过代理转发，支持平台：\n"
    printf "  ${CYAN}GitHub / Google / X (Twitter) / Yandex${NC}\n"
    printf "\n"
    printf "  若遇问题，查阅：${CYAN}docs/OAuth代理配置说明.md${NC}\n"
  else
    warning "Java 服务重启失败，请手动执行："
    printf "  ${CYAN}docker compose up -d --no-deps --force-recreate java-backend${NC}\n"
  fi
  printf "\n"
}

# 主函数
parse_version_selector() {
    local selector="${1:-}"
    if [ -n "$selector" ]; then
        if [[ "$selector" =~ ^v[0-9] ]]; then
            UPDATE_VERSION="$selector"
        elif [[ "$selector" =~ ^--?(latest|use-main|use-latest)$ ]]; then
            USE_LATEST_TAG=false
        fi
    fi
}

dispatch_command() {
    local command="${1:-}"
    shift || true

    case "$command" in
        "install"|"-install"|"--install"|"-deploy"|"-bushu"|"-bs"|"--deploy")
            run_deployment_with_args "$@"
            ;;
        "migrate"|"-migrate"|"--migrate"|"-qianyi"|"-qy"|"--qianyi"|"--qy")
            run_migration_with_args "$@"
            ;;
        "update"|"-update"|"--update")
            check_docker
            parse_version_selector "${1:-}"
            if [ -n "$UPDATE_VERSION" ]; then
                info "更新到指定版本: $UPDATE_VERSION"
            elif [ "$USE_LATEST_TAG" = "false" ]; then
                info "更新使用main分支"
            fi
            ensure_latest_poetize_for_update "${1:-}"
            run_update
            ;;
        "update-poetize-command"|"-update-poetize-command"|"--update-poetize-command")
            update_poetize_command
            ;;
        "uninstall"|"-uninstall"|"--uninstall")
            check_docker
            uninstall_services
            ;;
        "uninstall-all"|"-uninstall-all"|"--uninstall-all")
            check_docker
            uninstall_all_services
            ;;
        "status"|"-status"|"--status")
            check_docker
            show_status
            ;;
        "start"|"-start"|"--start"|"-up"|"--up")
            check_docker
            start_services
            ;;
        "stop"|"-stop"|"--stop"|"-down"|"--down")
            check_docker
            stop_services
            ;;
        "restart"|"-restart"|"--restart")
            check_docker
            restart_services
            ;;
        "logs"|"-logs"|"--logs")
            check_docker
            show_logs "${1:-}" "false"
            ;;
        "logs-follow"|"-logs-follow"|"--logs-follow")
            check_docker
            show_logs "${1:-}" "true"
            ;;
        "backup"|"-backup"|"--backup")
            check_docker
            backup_data "${1:-}"
            ;;
        "restore"|"-restore"|"--restore")
            check_docker
            restore_data "${1:-}"
            ;;
        "health"|"-health"|"--health")
            check_docker
            check_health
            ;;
        "info"|"-info"|"--info")
            show_info
            ;;
        "version"|"-version"|"--version"|"-v")
            show_version
            ;;
        "-oauth-proxy"|"oauth-proxy"|"--oauth-proxy")
            check_docker
            configure_oauth_proxy
            ;;
        "-enable-https"|"enable-https"|"--enable-https")
            check_docker
            enable_https
            ;;
        "help"|"-help"|"--help"|"-h")
            show_help
            ;;
        "")
            show_interactive_menu
            ;;
        *)
            error "未知选项: $command"
            printf "\n"
            show_help
            exit 1
            ;;
    esac
}

main() {
    ensure_accessible_workdir
    dispatch_command "${1:-}" "${@:2}"
}

# 运行主函数
main "$@"
