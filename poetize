  sed_i "s/your-email@example\.com/$EMAIL/g" docker-compose.yml
  
  # 统一检查并配置HTTPS模式
  check_and_configure_https_mode
  
  # 添加系统资源检查
  check_system_resources
  
  # 初始化部署
  init_deploy
  
  # 构建和启动Docker服务
  if ! start_services_with_diagnostics; then
    exit 1
  fi
  
  # 智能等待服务启动
  wait_for_services_ready
  
  # 对于真实域名，检查可访问性（在服务启动后进行）
  if [ "$PRIMARY_DOMAIN" != "localhost" ] && [ "$PRIMARY_DOMAIN" != "127.0.0.1" ] && ! [[ "$PRIMARY_DOMAIN" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    check_domains_access
  fi
  
  # 检查服务状态
  info "检查服务状态..."
  local python_required=0
  local _failed_services=()
  NGINX_RUNNING=$(sudo docker ps --filter "name=poetize-nginx" --format "{{.Status}}" | grep -c "Up")
  JAVA_RUNNING=$(sudo docker ps --filter "name=poetize-java" --format "{{.Status}}" | grep -c "Up")
  MYSQL_RUNNING=$(sudo docker ps --filter "name=poetize-mariadb" --format "{{.Status}}" | grep -c "Up")
  PRERENDER_RUNNING=$(sudo docker ps --filter "name=poetize-prerender" --format "{{.Status}}" | grep -c "Up")
  if project_requires_python_backend; then
    python_required=1
    PYTHON_RUNNING=$(sudo docker ps --filter "name=poetize-python" --format "{{.Status}}" | grep -c "Up")
  else
    PYTHON_RUNNING=1
  fi
  
  # 收集异常服务
  [ "$NGINX_RUNNING" -eq 1 ] || _failed_services+=("poetize-nginx")
  [ "$JAVA_RUNNING" -eq 1 ] || _failed_services+=("poetize-java")
  [ "$PYTHON_RUNNING" -eq 1 ] || _failed_services+=("poetize-python")
  [ "$MYSQL_RUNNING" -eq 1 ] || _failed_services+=("poetize-mariadb")
  [ "$PRERENDER_RUNNING" -eq 1 ] || _failed_services+=("poetize-prerender")

  if [ ${#_failed_services[@]} -eq 0 ]; then
    success "所有服务已成功启动！"
  else
    warning "部分服务可能未正常启动，请检查日志："
    echo "- Nginx状态: $([ "$NGINX_RUNNING" -eq 1 ] && echo '运行中' || echo '未运行')"
    echo "- Java后端状态: $([ "$JAVA_RUNNING" -eq 1 ] && echo '运行中' || echo '未运行')"
    if [ "$python_required" -eq 1 ]; then
      echo "- Python后端状态: $([ "$PYTHON_RUNNING" -eq 1 ] && echo '运行中' || echo '未运行')"
