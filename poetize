check_registry() {
  local registry=$1
  echo "检测 $registry..."
  # 30 秒整体超时、5 秒连接超时
  http_code=$(curl -sL --connect-timeout 5 --max-time 30 \
    -o /dev/null -w "%{http_code}" \
    "https://$registry/$IMAGE_URL" || echo "000")
  echo "HTTP $http_code"

  # 2xx、3xx、401 都认为是可用
  if [[ "$http_code" =~ ^2 || "$http_code" =~ ^3 || "$http_code" == "401" ]]; then
    return 0
  else
    return 1
  fi
}


