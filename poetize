mark_all_migrations_as_executed() {
  info "检查是否需要标记迁移脚本..."
  
  # 如果是更新模式（由 poetize -update 设置），跳过标记
  # 更新流程会通过 execute_additional_sql_scripts 正确处理迁移
  if [ "${POETIZE_UPDATE_MODE:-false}" = "true" ]; then
    info "检测到更新模式，跳过迁移脚本标记（将由 poetize -update 流程处理）"
    return 0
  fi
  
  # 获取数据库密码
  local db_root_password=""
  if [ -f ".config/db_credentials.txt" ]; then
    db_root_password=$(grep "数据库ROOT密码:" .config/db_credentials.txt | cut -d':' -f2 | tr -d ' ')
  fi
  
  if [ -z "$db_root_password" ]; then
    warning "无法获取数据库密码，跳过迁移版本标记"
    return 1
  fi
  
  # 查找MariaDB容器
  local mariadb_container=$(docker ps --format "{{.Names}}" | grep -E "mariadb|mysql" | head -1)
  if [ -z "$mariadb_container" ]; then
    warning "未找到数据库容器，跳过迁移版本标记"
    return 1
  fi
  
  # 等待数据库就绪
  local max_wait=60
  local wait_count=0
  while ! docker exec "$mariadb_container" mariadb -u root -p"$db_root_password" -e "SELECT 1" &>/dev/null; do
    sleep 2
    wait_count=$((wait_count + 2))
    if [ $wait_count -ge $max_wait ]; then
      warning "等待数据库就绪超时，跳过迁移版本标记"
      return 1
    fi
  done
  
  # 检查 db_migrations 表是否存在
  if ! docker exec "$mariadb_container" mariadb -u root -p"$db_root_password" poetize -N -e "SELECT 1 FROM db_migrations LIMIT 1" &>/dev/null; then
    warning "db_migrations 表不存在，跳过迁移版本标记"
    return 1
  fi
  
  # 检查 db_migrations 表是否有记录（判断是新安装还是升级）
  local existing_count=$(docker exec "$mariadb_container" mariadb -u root -p"$db_root_password" poetize -N -e "SELECT COUNT(*) FROM db_migrations" 2>/dev/null | tr -d '[:space:]')
  
  if [ -n "$existing_count" ] && [ "$existing_count" -gt 0 ]; then
    info "检测到已有 $existing_count 条迁移记录，这是升级操作，跳过自动标记"
    return 0
  fi
  
  info "检测到空的迁移记录表，这是新安装，标记所有脚本为已执行..."
  
  # 查找所有迁移脚本并标记为已执行
  if [ -d "poetize-server/sql" ]; then
    local sql_files=$(find poetize-server/sql -name "*.sql" -not -name "poetry.sql" -not -name "poetry_old.sql" -type f | sort)
    local count=0
    
    while IFS= read -r sql_file; do
      [ -z "$sql_file" ] && continue
      [ ! -f "$sql_file" ] && continue
      
      local version=$(basename "$sql_file" .sql)
      
      # 插入版本记录（如果不存在）
      docker exec "$mariadb_container" mariadb -u root -p"$db_root_password" poetize -e \
        "INSERT IGNORE INTO db_migrations (version, description, success) VALUES ('$version', '新安装时自动标记', 1)" 2>/dev/null
      
      count=$((count + 1))
    done <<< "$sql_files"
    
    success "已标记 $count 个迁移脚本为已执行（新安装）"
  fi
}

# 打印部署汇总信息
# 用法: print_summary [failed_service1 failed_service2 ...]
# 无参数表示所有服务正常
print_summary() {
  local BOLD='\033[1m'
  local GRAY='\033[90m'
  local https_enabled=false
  local ssl_certificate_path=""

  # 从参数接收异常服务列表（由调用方传入）
  local failed_services=("$@")
  local all_up=true
  if [ ${#failed_services[@]} -gt 0 ]; then
    all_up=false
  fi

  # 检查HTTPS是否真正启用
  if [ "$PRIMARY_DOMAIN" != "localhost" ] && [ "$PRIMARY_DOMAIN" != "127.0.0.1" ] && ! [[ "$PRIMARY_DOMAIN" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    ssl_certificate_path=$(docker exec poetize-nginx sh -c "nginx -T 2>/dev/null | awk '/ssl_certificate \\/etc\\/letsencrypt\\/live\\// {gsub(/;/, \"\", \$2); print \$2; exit}'" 2>/dev/null || true)
    if docker exec poetize-nginx nginx -T 2>/dev/null | grep -q "listen.*443.*ssl" && [ -n "$ssl_certificate_path" ] && docker exec poetize-nginx test -f "$ssl_certificate_path" 2>/dev/null; then
      https_enabled=true
    fi
  fi
  
  # 通用协议及访问地址
  local proto="http"
  [ "$https_enabled" = true ] && proto="https"
  local access_url="$PRIMARY_DOMAIN"
  if [ -n "$HTTP_PORT" ] && [ "$HTTP_PORT" != "80" ]; then
    access_url="$PRIMARY_DOMAIN:$HTTP_PORT"
  fi

  printf "\n"
  if [ "$all_up" = true ]; then
    printf "  ${GREEN}[ SUCCESS ]${NC}  ${BOLD}POETIZE ${RESOLVED_TARGET_VERSION} 部署成功！${NC}\n"
  else
    printf "  ${YELLOW}[ WARNING ]${NC}  ${BOLD}POETIZE ${RESOLVED_TARGET_VERSION} 部署完成 (部分服务异常)${NC}\n"
  fi
  printf "  ${GRAY}────────────────────────────────────────────────────────────${NC}\n"
  
  # 如果有异常服务，展示健康状况区块
  if [ "$all_up" = false ]; then
    printf "\n    ${RED}> 异常服务状况:${NC}\n"
    for svc in "${failed_services[@]}"; do
      printf "    - ${RED}$svc${NC}: ${RED}未启动或运行异常${NC}\n"
    done
    printf "    ${GRAY}提示: 请检查 $DOCKER_COMPOSE_CMD logs 查看详细报错信息${NC}\n"
  fi

  printf "\n    ${CYAN}> 访问入口:${NC}\n"
  printf "    - 网站首页: ${GREEN}$proto://%s${NC}\n" "$access_url"
  printf "    - 聊天室:   ${GREEN}$proto://%s/im${NC}\n" "$access_url"
  printf "    - 管理后台: ${GREEN}$proto://%s/admin${NC}\n" "$access_url"
  
  printf "\n    ${CYAN}> 安全与登录:${NC}\n"
  if [ "$https_enabled" = true ]; then
    printf "    - HTTPS 状态: ${GREEN}已开启 (SSL有效)${NC}\n"
  elif [ "$PRIMARY_DOMAIN" = "localhost" ] || [ "$PRIMARY_DOMAIN" = "127.0.0.1" ]; then
    printf "    - HTTPS 状态: ${YELLOW}本地环境 (跳过)${NC}\n"
  else
    printf "    - HTTPS 状态: ${RED}未启用${NC} ${YELLOW}(尝试执行 poetize -update 修复)${NC}\n"
  fi
  printf "    - 默认账号:   ${YELLOW}Sara / aaa${NC} ${RED}(登录后请务必修改密码！)${NC}\n"

  printf "\n    ${CYAN}> 快速管理:${NC}\n"
  if [ -L "/usr/local/bin/poetize" ] || [ -f "/usr/local/bin/poetize" ]; then
    printf "    - 常用命令:   ${GREEN}poetize -status | -restart | -help${NC}\n"
  else
    printf "    - 常用命令:   ${GREEN}%s ps | logs | help${NC}\n" "$DOCKER_COMPOSE_CMD"
  fi
  printf "    - 数据库凭据: 见 ${YELLOW}.config/db_credentials.txt${NC}\n"

  printf "\n"
  printf "  ${GRAY}────────────────────────────────────────────────────────────${NC}\n"
}

# 保存配置到文件
save_config() {
  local config_file=$1
  
  # 确保目录存在
  mkdir -p $(dirname "$config_file")
  
  # 将所有域名用空格连接
  local all_domains=$(IFS=" "; echo "${DOMAINS[*]}")
  
  # 保存配置到文件
  cat > "$config_file" << EOF
# POETIZE部署配置
# 保存时间: $(date)
DOMAINS="$all_domains"
PRIMARY_DOMAIN="$PRIMARY_DOMAIN"
EMAIL="$EMAIL"
ENABLE_HTTPS=$ENABLE_HTTPS
EOF

  success "配置已保存到 $config_file"
}

# 从文件加载配置
load_config() {
  local config_file=$1
  
  if [ ! -f "$config_file" ]; then
    warning "配置文件 $config_file 不存在"
    return 1
  fi
  
  # 导入配置文件
  source "$config_file"
  
  # 将DOMAINS字符串转换为数组
  IFS=' ' read -r -a DOMAINS <<< "$DOMAINS"
  
  success "从 $config_file 加载了配置"
  
  # 显示已加载的配置
  echo "- 主域名: $PRIMARY_DOMAIN"
  echo "- 所有域名: ${DOMAINS[*]}"
  echo "- 邮箱: $EMAIL"
  echo "- 启用HTTPS: $([ "$ENABLE_HTTPS" = true ] && echo '是' || echo '否')"
}

