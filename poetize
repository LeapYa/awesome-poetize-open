    esac

    if version_gte "$RESOLVED_TARGET_VERSION" "$PYTHON_MERGED_VERSION"; then
        return 1
    fi

    return 0
}

resolve_docker_compose_display() {
    if [ -n "$DOCKER_COMPOSE_CMD" ]; then
