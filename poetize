# 检测是否在WSL环境中
is_wsl() {
  # 检查/proc/version文件中是否包含Microsoft字符串
  if [ -f /proc/version ] && grep -q Microsoft /proc/version 2>/dev/null; then
    return 0  # 是WSL环境
  else
    return 1  # 不是WSL环境
  fi
}

# 检测是否在容器内运行（Docker / Podman / LXC）
is_in_container() {
  # 方法1: /.dockerenv 是 Docker 容器的标志性文件
  if [ -f /.dockerenv ]; then
    return 0
  fi
  # 方法2: 检查 /proc/1/cgroup 中是否包含容器特征关键字
  if [ -f /proc/1/cgroup ] && grep -qE 'docker|lxc|libpod|containerd|kubepods' /proc/1/cgroup 2>/dev/null; then
    return 0
  fi
  # 方法3: /run/.containerenv 是 Podman 容器的标志性文件
  if [ -f /run/.containerenv ]; then
    return 0
  fi
  return 1
}

# 启动并启用 Docker 服务（自动适配容器/非容器环境）
# 容器内无法使用 systemctl 管理宿主机 Docker，直接跳过
start_docker_service() {
  if is_in_container; then
    if [ -S /var/run/docker.sock ]; then
      success "检测到容器内环境，Docker Socket 已挂载，无需在容器内启动服务"
    else
      warning "检测到容器内环境，跳过 Docker 服务启动（systemctl 不可用）"
      warning "如需在容器内使用 Docker，请启动容器时挂载宿主机 Socket:"
      warning "  docker run -v /var/run/docker.sock:/var/run/docker.sock ..."
    fi
    return 0
  fi
  # 非容器环境：使用对应服务管理器启动并启用 Docker
  if command -v systemctl &>/dev/null; then
    sudo systemctl start docker 2>/dev/null || true
    sudo systemctl enable docker 2>/dev/null || true
  elif command -v rc-update &>/dev/null; then
    # Alpine OpenRC
    sudo rc-update add docker boot 2>/dev/null || true
    sudo service docker start 2>/dev/null || true
  elif command -v service &>/dev/null; then
    sudo service docker start 2>/dev/null || true
  else
    warning "无法确定服务管理器，请手动启动 Docker 服务"
  fi
}

# 创建全局poetize命令符号链接（静默执行）
create_global_poetize_command() {
  local poetize_script="$(get_safe_pwd)/poetize"
  local target_path="/usr/local/bin/poetize"
  
  # 检查poetize脚本是否存在
  if [ ! -f "$poetize_script" ]; then
    return 1
  fi
  
  sudo chmod +x "$poetize_script"

  # 静默检查sudo权限
  if ! sudo -n true 2>/dev/null; then
    # 尝试获取sudo权限，但不显示提示
    if ! sudo true 2>/dev/null; then
      return 1
    fi
  fi
  
  # 确保目标目录存在
  if [ ! -d "/usr/local/bin" ]; then
    sudo mkdir -p /usr/local/bin 2>/dev/null || return 1
  fi
  
  # 删除已存在的符号链接或文件
  if [ -L "$target_path" ] || [ -f "$target_path" ]; then
    sudo rm -f "$target_path" 2>/dev/null
  fi

  # 同步统一入口脚本
  if sudo cp "$poetize_script" "$target_path" 2>/dev/null; then
    sudo chmod +x "$target_path" 2>/dev/null
    return 0
  else
    return 1
  fi
}

