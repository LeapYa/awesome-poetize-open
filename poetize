      info "现代Docker安装通常已包含docker compose插件"
      auto_confirm "是否尝试下载Docker Compose二进制包进行安装? (y/n) [y=安装, n=跳过]: " "y" "-n 1 -r"
      if [[ $REPLY =~ ^[Yy]$ ]]; then
