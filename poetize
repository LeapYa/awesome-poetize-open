show_version() {
    local project_dir=""
    local project_version=""

    if [ -f "docker-compose.yml" ] && [ -f "poetize" ]; then
        project_dir="$(get_safe_pwd)"
    elif [ -n "$POETIZE_PROJECT_DIR" ] && [ -d "$POETIZE_PROJECT_DIR" ]; then
        project_dir="$POETIZE_PROJECT_DIR"
    elif set_project_context "$(get_safe_pwd)" 2>/dev/null; then
        project_dir="$POETIZE_PROJECT_DIR"
    fi

    project_version="$(resolve_project_version "$project_dir" 2>/dev/null || true)"

    printf "${GREEN}POETIZE 管理工具 v%s${NC}\n" "$POETIZE_VERSION"
    printf "作者: LeapYa\n"
    printf "项目: awesome-poetize-open\n"
    if [ -n "$project_version" ]; then
        printf "项目版本: %s\n" "$project_version"
    else
        printf "项目版本: 未检测到\n"
    fi
}

set_project_context() {
    local target_dir="${1:-$(get_safe_pwd)}"
    local resolved_dir=""

    resolved_dir=$(cd "$target_dir" 2>/dev/null && pwd -P) || return 1

    POETIZE_PROJECT_DIR="$resolved_dir"
    POETIZE_PROJECT_PARENT_DIR="$(dirname "$resolved_dir")"
    POETIZE_PROJECT_NAME="$(basename "$resolved_dir")"
    return 0
}

find_project_dir() {

    # 0. 优先检查环境变量 (CI环境)
    if [ -n "$POETIZE_PROJECT_DIR" ] && [ -d "$POETIZE_PROJECT_DIR" ]; then
        cd "$POETIZE_PROJECT_DIR" || exit 1
        set_project_context "$POETIZE_PROJECT_DIR"
        load_config_lib
        return 0
    fi

    # 1. 优先检查当前目录
    if [ -f "docker-compose.yml" ] && [ -f "poetize" ]; then
        # 简单确认为 poetize 项目
        set_project_context "$(get_safe_pwd)"
        load_config_lib
        return 0
    fi

    # 查找所有匹配目录，排除常见系统目录
    dirs=()
    while IFS= read -r dir; do
    dirs+=("$dir")
    done < <(sudo find / \
    \( -path /proc -o -path '/proc/*' -o -path /sys -o -path '/sys/*' -o -path /dev -o -path '/dev/*' -o -path /run -o -path '/run/*' -o -path /var/lib/docker -o -path '/var/lib/docker/*' \) -prune -o \
    -type d \( -iname "awesome-poetize-open" -o -iname "awesome-poetize-open-blog*" \) -print 2>/dev/null)

    # 过滤掉嵌套在另一个项目目录里的同名目录，避免更新时误选子目录后再次拉取一层项目
    local sorted_dirs=()
    local filtered_dirs=()
    while IFS= read -r dir; do
        sorted_dirs+=("$dir")
    done < <(printf "%s\n" "${dirs[@]}" | awk 'NF { print length($0) "\t" $0 }' | sort -n | cut -f2-)
    dirs=("${sorted_dirs[@]}")
    for dir in "${dirs[@]}"; do
        local is_nested=false
        for kept_dir in "${filtered_dirs[@]}"; do
            case "$dir" in
                "$kept_dir"/*)
                    is_nested=true
                    break
                    ;;
            esac
        done

        if [ "$is_nested" = false ]; then
            filtered_dirs+=("$dir")
        fi
    done
    dirs=("${filtered_dirs[@]}")

    if [ ${#dirs[@]} -eq 0 ]; then
        echo "未发现poetize博客相关目录"
        exit 1
    elif [ ${#dirs[@]} -eq 1 ]; then
        echo "发现一个博客目录: ${dirs[0]}"
        cd "${dirs[0]}" || { echo "切换目录失败: ${dirs[0]}"; exit 1; }
        set_project_context "${dirs[0]}"
        load_config_lib  # 加载配置管理库
    else
        echo "发现多个博客目录："
        for i in "${!dirs[@]}"; do
            printf "%d. %s\n" "$((i+1))" "${dirs[i]}"
        done

        # 交互输入
        read -rp "请选择要操作的项目目录序号: " choice

        # 判断输入有效性
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#dirs[@]} )); then
            echo "无效的选择."
            exit 1
        fi

        target_dir="${dirs[$((choice-1))]}"
        echo "已选择项目目录: $target_dir"
        cd "$target_dir" || { echo "切换目录失败: $target_dir"; exit 1; }
        set_project_context "$target_dir"
        load_config_lib  # 加载配置管理库
    fi
}

# 查看服务状态
show_status() {
    info "正在检查POETIZE服务状态..."
    printf "\n"

    local core_services=("poetize-nginx" "poetize-java" "poetize-prerender")
    local optional_services=("poetize-mariadb" "poetize-redis")
    local ephemeral_services=("poetize-web" "poetize-admin")
    local instances=""
    local container_name=""
    local info=""
    local service_status=""
    local service_message=""

    print_section_header "服务状态概览"
    print_table_header
    for base_service in "${core_services[@]}"; do
        instances="$(list_service_instances "$base_service")"
        if [ -z "$instances" ]; then
            print_table_row "FAIL" "$base_service" "常驻服务" "未发现容器"
            continue
        fi

        while IFS= read -r container_name; do
            [ -z "$container_name" ] && continue
            info="$(get_service_runtime_status "$container_name")"
            service_status="${info%%|*}"
            service_message="${info#*|}"
            print_table_row "$service_status" "$container_name" "常驻服务" "$service_message"
        done <<< "$instances"
    done

    for base_service in "${optional_services[@]}"; do
        instances="$(list_service_instances "$base_service")"
        if [ -z "$instances" ]; then
            print_table_row "INFO" "$base_service" "可选服务" "未启用或使用外部服务"
            continue
        fi

        while IFS= read -r container_name; do
            [ -z "$container_name" ] && continue
            info="$(get_service_runtime_status "$container_name")"
            service_status="${info%%|*}"
            service_message="${info#*|}"
            print_table_row "$service_status" "$container_name" "可选服务" "$service_message"
        done <<< "$instances"
    done

    for base_service in "${ephemeral_services[@]}"; do
        instances="$(list_service_instances "$base_service")"
        if [ -z "$instances" ]; then
            print_table_row "INFO" "$base_service" "一次性容器" "未发现容器记录"
            continue
        fi

        while IFS= read -r container_name; do
            [ -z "$container_name" ] && continue
            info="$(print_ephemeral_service_status "$container_name")"
            service_status="${info%%|*}"
            service_message="${info#*|}"
            print_table_row "$service_status" "$container_name" "一次性容器" "$service_message"
        done <<< "$instances"
    done
    if project_requires_python_backend; then
        print_table_row "INFO" "poetize-python" "兼容服务" "当前部署版本仍使用独立 Python 后端"
    else
        print_table_row "INFO" "poetize-python" "备注" "v4.0.0 起已并入 poetize-java"
    fi
    print_table_row "INFO" "-" "备注" "poetize-web / poetize-admin 仅用于构建静态资源，退出不代表项目异常"

    printf "\n"

    print_section_header "端口占用情况"
    print_table_header
    local port_bindings=""
    local binding=""
    local host_port=""
    local container_port=""
    port_bindings="$(list_nginx_port_bindings)"
    if [ -z "$port_bindings" ]; then
        print_table_row "INFO" "-" "网络端口" "未发现 nginx 端口映射"
    else
        while IFS= read -r binding; do
            [ -z "$binding" ] && continue
            host_port="${binding%%|*}"
            container_port="${binding#*|}"
            if netstat -tuln 2>/dev/null | grep -q ":${host_port} " || ss -tuln 2>/dev/null | grep -q ":${host_port} "; then
                print_table_row "OK" "端口 $host_port" "网络端口" "已占用 -> ${container_port}"
            else
                print_table_row "FAIL" "端口 $host_port" "网络端口" "未占用 -> ${container_port}"
            fi
        done <<< "$port_bindings"
    fi
    
    printf "\n"
}

# 启动服务
start_services() {
    find_project_dir
    info "正在启动POETIZE服务..."

    local previous_skip_build="$SKIP_BUILD"
    if [ -z "$SKIP_BUILD" ]; then
        SKIP_BUILD="--no-build"
    fi

    if [ -z "$DOCKER_COMPOSE_CMD" ]; then
        error "未找到可用的 Docker Compose 命令"
        SKIP_BUILD="$previous_skip_build"
        exit 1
    fi

    if $DOCKER_COMPOSE_CMD up -d $SKIP_BUILD; then
        SKIP_BUILD="$previous_skip_build"
        success "服务启动成功"
        sleep 3
        show_status
    else
        SKIP_BUILD="$previous_skip_build"
        error "服务启动失败"
        exit 1
    fi
}

# 停止服务
stop_services() {
    find_project_dir
    info "正在停止POETIZE服务..."
    if $DOCKER_COMPOSE_CMD down; then
        success "服务停止成功"
    else
        error "服务停止失败"
        exit 1
    fi
}

# 重启服务
restart_services() {
    find_project_dir
    info "正在重启POETIZE服务..."

    if $DOCKER_COMPOSE_CMD restart; then
        success "服务重启成功"
        sleep 3
        show_status
    else
        error "服务重启失败"
        exit 1
    fi
}

# 卸载当前项目服务
uninstall_services() {
    local skip_confirm=false
    
    # 检查是否有--skip-confirm参数
    if [ "$1" = "--skip-confirm" ]; then
        skip_confirm=true
    fi
    
    # 只有在非跳过模式下才查找项目目录和显示警告
    if [ "$skip_confirm" = false ]; then
        find_project_dir
        warning "此操作将卸载当前项目的POETIZE系统，包括删除相关容器和数据卷！"
        printf "${RED}警告: 这将删除当前项目的博客数据，此操作不可逆！${NC}\n"
        printf "\n"
        
        # 确认操作
        read -rp "请输入 'YES' 确认卸载当前项目: " confirm
        if [ "$confirm" != "YES" ]; then
            info "卸载操作已取消"
            exit 0
        fi
        info "正在卸载当前项目的POETIZE系统..."
    fi
    
    # 获取当前项目的容器名称（用于识别相关卷）
    local project_containers=$($DOCKER_COMPOSE_CMD ps -q 2>/dev/null || true)
    local project_name=$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]//g')
    
    # 停止并删除当前项目的容器和卷
    info "停止并删除当前项目容器..."
    $DOCKER_COMPOSE_CMD down -v --remove-orphans
    
    # 仅清理通过docker-compose创建的项目专属卷
    info "检查并清理当前项目专属数据卷..."
    
    # 获取当前项目的docker-compose生成的卷名前缀
    local compose_project_name=$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]')
    
    # 清理当前项目的卷（通过docker-compose down -v应该已经删除了，但防止遗漏）
    local project_specific_volumes=$(sudo docker volume ls --format "{{.Name}}" | grep "^${compose_project_name}_" || true)
    if [ -n "$project_specific_volumes" ]; then
        info "删除当前项目专属数据卷..."
        while IFS= read -r volume; do
            info "删除数据卷: $volume"
            sudo docker volume rm "$volume" -f 2>/dev/null || true
        done <<< "$project_specific_volumes"
        success "已删除当前项目专属数据卷"
    else
        info "当前项目无需清理额外数据卷（已通过docker-compose清理）"
    fi

    sudo docker system prune -f 2>/dev/null || true
    
    success "当前项目的POETIZE系统已卸载"
    
    # 如果是跳过确认模式（用于更新流程），则删除项目目录
    if [ "$skip_confirm" = true ]; then
        local current_dir="${POETIZE_PROJECT_DIR:-$(pwd)}"
        local current_parent_dir="${POETIZE_PROJECT_PARENT_DIR:-$(dirname "$current_dir")}"
        info "正在删除项目目录: $current_dir"
        cd "$current_parent_dir" || {
            error "无法切换到项目父目录: $current_parent_dir"
            return 1
        }
        sudo rm -rf "$current_dir"
        if [ -e "$current_dir" ]; then
            error "项目目录删除失败，已停止更新以避免在旧目录内再次拉取新项目: $current_dir"
            return 1
        fi
        info "项目目录已删除"
    else
        warning "如需重新安装，请运行: poetize -deploy"
    fi
}

# 完全卸载所有POETIZE系统
uninstall_all_services() {
    warning "此操作将完全卸载所有POETIZE系统，包括删除所有容器、镜像、卷和数据！"
    printf "${RED}警告: 这将删除所有博客数据，此操作不可逆！${NC}\n"
    printf "\n"
    
    # 确认操作
    read -rp "请输入 'YES' 确认完全卸载所有POETIZE系统: " confirm
    if [ "$confirm" != "YES" ]; then
        info "卸载操作已取消"
        exit 0
    fi
    
    info "正在完全卸载所有POETIZE系统..."
    
    # 删除所有poetize相关的容器（包括停止的）
    local containers=$(sudo docker ps -a --format "{{.Names}}" | grep "^poetize-" || true)
    if [ -n "$containers" ]; then
        info "删除所有POETIZE容器..."
        echo "$containers" | xargs sudo docker rm -f
    fi
    
    # 删除所有poetize相关的镜像
    local images=$(sudo docker images --format "{{.Repository}}:{{.Tag}}" | grep "poetize" || true)
    if [ -n "$images" ]; then
        info "删除所有POETIZE镜像..."
        echo "$images" | xargs sudo docker rmi -f
    fi
    
    # 删除所有poetize相关的卷（包括默认卷名和带后缀的卷）
    info "检查并删除所有POETIZE数据卷..."
    
    # 定义需要清理的卷名称模式
    local volume_patterns=(
        "mysql_data"
        "redis_data" 
        "certbot-etc"
        "certbot-var"
        "web-root"
        # node_modules volumes 已移除（前端构建优化后不再需要）
        # "poetize_node_modules"
        # "im_node_modules"
        # 新版前端卷
        "poetize_web_dist"
        "poetize_admin_dist"
        # 旧版前端卷（向后兼容）
        "poetize_ui_dist"
        "poetize_im_dist"
        "poetize_uploads"
        "ollama_data"
    )
    
    local volumes_to_delete=()
    
    # 1. 查找包含POETIZE的卷
    local poetize_volumes=$(sudo docker volume ls --format "{{.Name}}" | grep "poetize" || true)
    if [ -n "$poetize_volumes" ]; then
        while IFS= read -r volume; do
            volumes_to_delete+=("$volume")
        done <<< "$poetize_volumes"
    fi
    
    # 2. 查找所有可能的默认卷名（包括各种前缀和后缀）
    for pattern in "${volume_patterns[@]}"; do
        # 完全匹配的卷名
        local exact_volumes=$(sudo docker volume ls --format "{{.Name}}" | grep "^${pattern}$" || true)
        if [ -n "$exact_volumes" ]; then
            while IFS= read -r volume; do
                volumes_to_delete+=("$volume")
            done <<< "$exact_volumes"
        fi
        
        # 带项目前缀的卷名
        local prefixed_volumes=$(sudo docker volume ls --format "{{.Name}}" | grep "_${pattern}$" || true)
        if [ -n "$prefixed_volumes" ]; then
            while IFS= read -r volume; do
                volumes_to_delete+=("$volume")
            done <<< "$prefixed_volumes"
        fi
        
        # 带后缀的卷名（blog2、blog3等）
        local suffixed_volumes=$(sudo docker volume ls --format "{{.Name}}" | grep "^${pattern}-blog[0-9]*$" || true)
        if [ -n "$suffixed_volumes" ]; then
            while IFS= read -r volume; do
                volumes_to_delete+=("$volume")
            done <<< "$suffixed_volumes"
        fi
        
        # 带前缀和后缀的卷名
        local complex_volumes=$(sudo docker volume ls --format "{{.Name}}" | grep "_${pattern}-blog[0-9]*$" || true)
        if [ -n "$complex_volumes" ]; then
            while IFS= read -r volume; do
                volumes_to_delete+=("$volume")
            done <<< "$complex_volumes"
        fi
    done
    
    # 去重并删除卷
    if [ ${#volumes_to_delete[@]} -gt 0 ]; then
        # 去重
        local unique_volumes=($(printf "%s\n" "${volumes_to_delete[@]}" | sort -u))
        
        info "找到 ${#unique_volumes[@]} 个POETIZE数据卷，准备删除..."
        for volume in "${unique_volumes[@]}"; do
            info "删除数据卷: $volume"
            sudo docker volume rm "$volume" -f 2>/dev/null || true
        done
        success "已删除 ${#unique_volumes[@]} 个POETIZE数据卷"
    else
        info "未找到需要清理的POETIZE数据卷"
    fi
    
    # 删除所有poetize相关的网络
    local networks=$(sudo docker network ls --format "{{.Name}}" | grep "poetize" || true)
    if [ -n "$networks" ]; then
        info "删除所有POETIZE网络..."
        echo "$networks" | xargs sudo docker network rm
    fi
    
    # 清理未使用的Docker资源
    info "清理未使用的Docker资源..."
    sudo docker system prune -f
    
    success "所有POETIZE系统已完全卸载"
    warning "如需重新安装，请运行: poetize -deploy"
}

