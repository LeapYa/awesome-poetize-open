}

status_rank() {
    case "$1" in
        "FAIL") echo 3 ;;
        "WARN") echo 2 ;;
        "OK") echo 1 ;;
        *) echo 0 ;;
    esac
}

merge_status() {
    local current="$1"
    local incoming="$2"
    if [ "$(status_rank "$incoming")" -gt "$(status_rank "$current")" ]; then
        printf "%s\n" "$incoming"
    else
        printf "%s\n" "$current"
    fi
}

get_service_runtime_status() {
    local container_name="$1"
    local state
    local health

    state=$(sudo docker inspect --format='{{.State.Status}}' "$container_name" 2>/dev/null || echo "not-found")
    if [ "$state" != "running" ]; then
        printf "FAIL|未运行(%s)\n" "$state"
        return 1
    fi

    health=$(sudo docker inspect --format='{{if .State.Health}}{{.State.Health.Status}}{{else}}no-healthcheck{{end}}' "$container_name" 2>/dev/null || echo "unknown")
    case "$health" in
        "healthy")
            printf "OK|健康\n"
            ;;
        "starting")
            printf "WARN|启动中\n"
            ;;
        "unhealthy")
            printf "FAIL|不健康\n"
            return 1
            ;;
        *)
            printf "INFO|运行中(无健康检查)\n"
            ;;
    esac
}

print_ephemeral_service_status() {
    local container_name="$1"
    local state

    state=$(sudo docker inspect --format='{{.State.Status}}' "$container_name" 2>/dev/null || echo "not-found")
    case "$state" in
        "exited")
            printf "OK|已完成并正常退出\n"
            ;;
        "running")
            printf "WARN|正在执行一次性任务\n"
            ;;
        "created"|"restarting")
            printf "WARN|%s\n" "$state"
            ;;
        "not-found")
            printf "INFO|未发现容器记录\n"
            ;;
        *)
            printf "INFO|%s\n" "$state"
            ;;
    esac
}

ensure_embedded_core_dir() {
    if [ -n "$EMBEDDED_CORE_DIR" ] && [ -d "$EMBEDDED_CORE_DIR" ]; then
