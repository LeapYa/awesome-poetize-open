        return 0
    fi

    if sudo docker compose version >/dev/null 2>&1; then
        printf "sudo docker compose\n"
        return 0
    fi

    if command -v docker-compose >/dev/null 2>&1 && docker-compose --version >/dev/null 2>&1; then
        printf "docker-compose\n"
        return 0
    fi

    if sudo docker-compose --version >/dev/null 2>&1; then
        printf "sudo docker-compose\n"
        return 0
    fi

