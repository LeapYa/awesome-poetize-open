get_script_dir() {
    local script_path
    script_path="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
    dirname "$script_path"
}

get_safe_pwd() {
    pwd -P 2>/dev/null && return 0

    if [ -n "$POETIZE_PROJECT_DIR" ] && [ -d "$POETIZE_PROJECT_DIR" ]; then
        printf "%s\n" "$POETIZE_PROJECT_DIR"
        return 0
    fi

    local script_dir
    script_dir="$(get_script_dir)"
    if [ -d "$script_dir" ]; then
        printf "%s\n" "$script_dir"
        return 0
    fi

    if [ -n "$HOME" ] && [ -d "$HOME" ]; then
        printf "%s\n" "$HOME"
        return 0
    fi

    printf "/\n"
}

ensure_accessible_workdir() {
    pwd -P >/dev/null 2>&1 && return 0

    local fallback_dir
    fallback_dir="$(get_safe_pwd)"
    cd "$fallback_dir" 2>/dev/null || cd / 2>/dev/null || return 1
